rquet')\n) AS cities\nON ST_Intersects(neighborhoods.geom, cities.geom);\n\"\"\"\n)","key":"DfQhY24IsK"},{"type":"outputs","id":"cf3VKPOyFsl1_FUI9A3YO","children":[],"key":"tekmvG1sVT"}],"key":"Sd0qPeb0kz"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":259,"column":1},"end":{"line":259,"column":1}},"children":[{"type":"text","value":"Spatial Relationship Functions Reference","position":{"start":{"line":259,"column":1},"end":{"line":259,"column":1}},"key":"YOxSqTXU7a"}],"identifier":"spatial-relationship-functions-reference","label":"Spatial Relationship Functions Reference","html_id":"spatial-relationship-functions-reference","implicit":true,"key":"rVum1zUSKU"},{"type":"heading","depth":3,"position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"children":[{"type":"text","value":"Core Spatial Predicates","position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"key":"txabEYoXiy"}],"identifier":"core-spatial-predicates","label":"Core Spatial Predicates","html_id":"core-spatial-predicates","implicit":true,"key":"dGbrgedyrT"},{"type":"heading","depth":3,"position":{"start":{"line":263,"column":1},"end":{"line":263,"column":1}},"children":[{"type":"text","value":"Choosing the Right Predicate","position":{"start":{"line":263,"column":1},"end":{"line":263,"column":1}},"key":"YnAVFnVbsq"}],"identifier":"choosing-the-right-predicate","label":"Choosing the Right Predicate","html_id":"choosing-the-right-predicate","implicit":true,"key":"RkZ2DkJJei"},{"type":"heading","depth":2,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"CQHV2g5AIH"}],"identifier":"key-takeaways","label":"Key Takeaways","html_id":"key-takeaways","implicit":true,"key":"nKIMRISJ8T"},{"type":"heading","depth":2,"position":{"start":{"line":267,"column":1},"end":{"line":267,"column