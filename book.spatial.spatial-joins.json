SELECT DISTINCT routes\nFROM nyc_subway_stations AS subways\nWHERE strpos(subways.routes,'A') > 0;\n\"\"\"\n)","key":"wTRghure1D"},{"type":"outputs","id":"hQxa2z54_c7IWB5mbMPIF","children":[],"key":"O2CuJ0bsMT"}],"key":"bClsJL9Fgn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n  100.0 * Sum(popn_white) / Sum(popn_total) AS white_pct,\n  100.0 * Sum(popn_black) / Sum(popn_total) AS black_pct,\n  Sum(popn_total) AS popn_total\nFROM nyc_census_blocks AS census\nJOIN nyc_subway_stations AS subways\nON ST_DWithin(census.geom, subways.geom, 200)\nWHERE strpos(subways.routes,'A') > 0;\n\"\"\"\n)","key":"hcSH36EZjL"},{"type":"outputs","id":"IuTmqhqn1oFHlPiY56MVX","children":[],"key":"uJQhFaJkwl"}],"key":"BGiXtJQEbu"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"children":[{"type":"text","value":"Advanced Join","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"key":"ei0eQYWWpb"}],"identifier":"advanced-join","label":"Advanced Join","html_id":"advanced-join","implicit":true,"key":"nufV0AOUoa"}],"key":"vyCcMxcGnM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nCREATE OR REPLACE TABLE subway_lines ( route char(1) );\nINSERT INTO subway_lines (route) VALUES\n  ('A'),('B'),('C'),('D'),('E'),('F'),('G'),\n  ('J'),('L'),('M'),('N'),('Q'),('R'),('S'),\n  ('Z'),('1'),('2'),('3'),('4'),('5'),('6'),\n  ('7');\n\"\"\"\n)","key":"eFQwtkaP9M"},{"type":"outputs","id":"h5tRs7wzoxJZ6upth4zyK","children":[],"key":"JBsYsrKriU"}],"key":"fqEVTAAtdT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n  lines.route,\n  100.0 * Sum(popn_white) / Sum(popn_total) AS white_pct,\n  100.0 * Sum(popn_black) / Sum(popn_total) AS black_pct,\n  Sum(popn_total) AS popn_total\nFROM nyc_census_blocks AS census\nJOIN nyc_subway_stations AS subways\nON ST_DWithin(census.geom, subways.geom, 200)\nJOIN subway_lines AS lines\nON strpos(subways.routes, lines.route) > 0\nGROUP BY lines.route\nORDER BY black_pct DESC;\n\"\"\"\n)","key":"ZgtFMUmHn1"},{"type":"outputs","id":"Ax2r6fZT9AqzLhVq-g5jJ","children":[],"key":"rK3ivV5ck1"}],"key":"UgJYygf3hv"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Coordinate System Transformations","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"QhaDjwZBQT"}],"identifier":"coordinate-system-transformations","label":"Coordinate System Transformations","html_id":"coordinate-system-transformations","implicit":true,"key":"Qom7p6GR2T"},{"type":"heading","depth":3,"position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"children":[{"type":"text","value":"Transforming Geographic to Projected Coordinates","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"key":"LfOyr1Lshd"}],"identifier":"transforming-geographic-to-projected-coordinates","label":"Transforming Geographic to Projected Coordinates","html_id":"transforming-geographic-to-projected-coordinates","implicit":true,"key":"RaokgeE369"}],"key":"UWlTBLyF1d"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://data.gishub.org/duckdb/cities.parquet\"\ncon.sql(f\"SELECT * FROM '{url}'\")","key":"FSkYBJc96a"},{"type":"outputs","id":"RZjiG659Zd2yze2ByPjTr","children":[],"key":"QFvck2EYel"}],"key":"jXA6Uo90Xr"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"children":[{"type":"text","value":"Applying the Transformation","position":{"start":{"line":228,"column":1},"end":{"line":228,"col