":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"Jvn0hBbiQp"}],"identifier":"understanding-duckdb-relations","label":"Understanding DuckDB Relations","html_id":"understanding-duckdb-relations","implicit":true,"key":"nGkvTQZARp"}],"key":"Gzvj3DIwWN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cities = con.read_csv(\"https://data.gishub.org/duckdb/cities.csv\")\nlarge_cities = cities.filter(\"population > 1000000\").order(\"population DESC\").limit(10)\nlarge_cities.show()","key":"PkGieZrgrX"},{"type":"outputs","id":"npXlCdoWqXI2DyytS9QqB","children":[],"key":"RGk7XNF1Xd"}],"key":"GfdgPjVQlH"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"Seamless Integration with Pandas DataFrames","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"rDxECJHcrs"}],"identifier":"seamless-integration-with-pandas-dataframes","label":"Seamless Integration with Pandas DataFrames","html_id":"seamless-integration-with-pandas-dataframes","implicit":true,"key":"xPiFQ0PoyF"},{"type":"heading","depth":3,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Querying DataFrames with SQL","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"NM0kehhQ3l"}],"identifier":"querying-dataframes-with-sql","label":"Querying DataFrames with SQL","html_id":"querying-dataframes-with-sql","implicit":true,"key":"SF3OlUFT0h"}],"key":"x0XfTFe7Oh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pandas_df = pd.DataFrame({\"a\": [42]})\ncon.sql(\"SELECT * FROM pandas_df\")","key":"nih0wBTjgN"},{"type":"outputs","id":"-_rYynxHaavP5S8PZJWxE","children":[],"key":"E9RGcs3FZq"}],"key":"n80GihBphs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load cities data into a pandas DataFrame\ncities_df = con.read_csv(\"https://data.gishub.org/duckdb/cities.csv\").df()\nprint(f\"Loaded {len(cities_df)} cities into pandas DataFrame\")\ncities_df.head()","key":"KJH7k3SK73"},{"type":"outputs","id":"DJHeT3SO0VIvjPvBE2a3u","children":[],"key":"OJittAIcBm"}],"key":"HhW9mYsOrh"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"The Bidirectional Workflow","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"Z5nT3xKLqt"}],"identifier":"the-bidirectional-workflow","label":"The Bidirectional Workflow","html_id":"the-bidirectional-workflow","implicit":true,"key":"HupCTts7co"}],"key":"Bd9qh2Dest"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Query the pandas DataFrame using SQL\nlarge_cities = con.sql(\n    \"\"\"\n    SELECT name, country, population\n    FROM cities_df\n    WHERE population > 5000000\n    ORDER BY population DESC\n    LIMIT 10\n\"\"\"\n)\nlarge_cities.show()","key":"PGDWtnALVo"},{"type":"outputs","id":"mZFc7X3chhyBCvXocvJVz","children":[],"key":"cQ1lKRAF06"}],"key":"VEYEx4HMTN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Step 1: Use SQL for initial filtering (DuckDB's strength)\ncities_rel = con.sql(\n    \"\"\"\n    SELECT * FROM read_csv_auto('https://data.gishub.org/duckdb/cities.csv')\n    WHERE population > 100000\n\"\"\"\n)\n\n# Step 2: Convert to DataFrame for pandas operations\ncities_df = cities_rel.df()\n\n# Step 3: Use pandas for complex transformations\ncities_df[\"pop_millions\"] = cities_df[\"population\"] / 1_000_000\ncities_df[\"hemisphere\"] = cities_df[\"latitude\"].apply(\n    lambda x: \"North\" if x > 0 else \"South\"\n)\n\n# Step 4: Query the transformed DataFrame with SQL\nresult = con.sql(\n    \"\"\"\n    SELECT hemisphere, COUNT(*) as city_count,\n           AVG(pop_millions) as avg_pop_millions\n    FROM cities_df\n    GROUP BY hemisphere\n\"\"\"\n)\nresult.show()","key":"LJ3Kq6sBr3"},{"type":"outputs","id":"re-zn0cHWrhI-Cb7TeAtH","children":[],"key":"f3r1bKi4U8"}],"key":"GG1G0zUJk4"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Performance Considerations","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"wZfhoc9vph"}],"identifier":"performance-considerations","label":"Performance Considerations","html_id":"performance-considerations","implicit":true,"key":"w23ZuPh2aj"},{"type":"heading","depth":2,"position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"Polars Interoperability","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"vrKMCIoAAo"}],"identifier":"polars-interoperability","label":"Polars Interoperability","html_id":"polars-interoperability","implicit":true,"key":"EewA1RTFZo"}],"key":"yabeUylmk9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# %pip install polars\nimport polars as pl\n\n# Convert DuckDB result to Polars via pandas\npl_df = pl.from_pandas(con.sql(\"SELECT * FROM range(10)\").df())\npl_df.head()\n\n# Query Polars DataFrame in DuckDB\ncon.sql(\"SELECT COUNT(*) AS n FROM pl_df\")","key":"lsVogmx2vf"},{"type":"outputs","id":"E42jXcEjkLAKllSdJRo5v","children":[],"key":"xA8iQ4G5nA"}],"key":"pmoXitVtBt"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"Result Conversion and Output Formats","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"ECpoZQq9aP