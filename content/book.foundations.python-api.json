e":217,"column":1}},"children":[{"type":"text","value":"Creating a Persistent Database","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"qd5YEVOR6v"}],"identifier":"creating-a-persistent-database","label":"Creating a Persistent Database","html_id":"creating-a-persistent-database","implicit":true,"key":"X36YlcCpQl"}],"key":"mE7OjJhQou"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create or open a connection to a file called 'spatial_analysis.db'\ncon = duckdb.connect(\"spatial_analysis.db\")\n\n# Create a table and load data into it\ncon.sql(\n    \"\"\"\n    CREATE TABLE IF NOT EXISTS cities AS\n    FROM read_csv_auto('https://data.gishub.org/duckdb/cities.csv')\n\"\"\"\n)\n\n# Query the table to verify it was created\ncon.table(\"cities\").show()","key":"UQPOSTdsog"},{"type":"outputs","id":"-xVMKjINHUCwKhiMUQRA5","children":[],"key":"K5ujB0sr59"}],"key":"AqylNcgOg6"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":235,"column":1},"end":{"line":235,"column":1}},"children":[{"type":"text","value":"Connecting to Existing Databases","position":{"start":{"line":235,"column":1},"end":{"line":235,"column":1}},"key":"wJdh7TU3SE"}],"identifier":"connecting-to-existing-databases","label":"Connecting to Existing Databases","html_id":"connecting-to-existing-databases","implicit":true,"key":"ELU2HjKwv8"}],"key":"vuIiQQTfQG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# In a new Python session or later in your workflow\ncon = duckdb.connect(\"spatial_analysis.db\")\n\n# All your tables are still there\ncon.sql(\"SHOW TABLES\").show()\n\n# Query your persisted data\ncon.sql(\"SELECT COUNT(*) FROM cities\").show()","key":"HFSo5RuXrk"},{"type":"outputs","id":"wuXmO3VwuvL0IoTvw3ASa","children":[],"key":"g0HquNegiz"}],"key":"ac7R1nDLUZ"},{"type":"block","children":[{"type":"heading","d