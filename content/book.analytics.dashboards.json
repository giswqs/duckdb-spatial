":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"nA4vQXjByl"}],"identifier":"setting-up-the-map-and-imports","label":"Setting Up the Map and Imports","html_id":"setting-up-the-map-and-imports","implicit":true,"key":"HlqqjQOfYl"}],"key":"DN9YV1awzU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import json\nimport duckdb\nimport ipywidgets as widgets\nimport leafmap.maplibregl as leafmap\nimport matplotlib.pyplot as plt\n\nm = leafmap.Map(sidebar_visible=True, layer_manager_expanded=False, height=\"800px\")\nm.add_basemap(\"Esri.WorldImagery\", before_id=m.first_symbol_layer_id, visible=False)\nm.add_draw_control(controls=[\"polygon\", \"trash\"])\nm","key":"lpDwmRbQot"},{"type":"outputs","id":"CUyEQvgaPgg7Ngz6CyYl2","children":[],"key":"l8036Lhftm"}],"key":"pVt4YWZV8H"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"Initializing the DuckDB Connection","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"w0EwvPXr9V"}],"identifier":"initializing-the-duckdb-connection","label":"Initializing the DuckDB Connection","html_id":"initializing-the-duckdb-connection","implicit":true,"key":"kgsV2uPjqw"}],"key":"Y3Xr2ABzru"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con = duckdb.connect()\ncon.install_extension(\"httpfs\")\ncon.install_extension(\"spatial\")\ncon.install_extension(\"h3\", repository=\"community\")\ncon.load_extension(\"httpfs\")\ncon.load_extension(\"spatial\")\ncon.load_extension(\"h3\")","key":"PnLcF5rtaZ"},{"type":"outputs","id":"2ffwYqmcePvRxn9Pxx86k","children":[],"key":"h9rxftw1ZJ"}],"key":"UvRAu7qFzx"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"Loading the Building Data","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"kCv143GDns"}],"identifier":"loading-the-building-data","label":"Loading the Building Data","html_id":"loading-the-building-data","implicit":true,"key":"Q2ATEuP34B"}],"key":"J8LQ3tWnHW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://data.gishub.org/duckdb/h3_res4_geo.parquet\"\n\ncon.sql(\n    f\"CREATE TABLE IF NOT EXISTS h3_res4_geo AS SELECT * FROM read_parquet('{url}');\"\n)","key":"nPTSJyocbe"},{"type":"outputs","id":"jocVEvpfKWU0YaXsQAN4B","children":[],"key":"xydLELJK6D"}],"key":"ddpxwm6peG"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"children":[{"type":"text","value":"Creating the User Interface Controls","position":{"start":{"line":105,"column":1},"end":{"line":105,"column":1}},"key":"yDjPcXRfJr"}],"identifier":"creating-the-user-interface-controls","label":"Creating the User Interface Controls","html_id":"creating-the-user-interface-controls","implicit":true,"key":"Tt92RkTNee"}],"key":"FD201ifRDS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"colormaps = sorted(plt.colormaps())\n\ncheckbox = widgets.Checkbox(\n    description=\"3D Map\",\n    value=True,\n    style={\"description_width\": \"initial\"},\n    layout=widgets.Layout(width=\"initial\"),\n)\noutline_chk = widgets.Checkbox(\n    description=\"Add Hexagon Outline\",\n    value=False,\n    style={\"description_width\": \"initial\"},\n    layout=widgets.Layout(width=\"initial\"),\n)\n\ncolormap_dropdown = widgets.Dropdown(\n    options=colormaps,\n    description=\"Colormap:\",\n    value=\"inferno\",\n    style={\"description_width\": \"initial\"},\n)\nclass_slider = widgets.IntSlider(\n    description=\"Class:\",\n    min=1,\n    max=10,\n    step=1,\n    value=5,\n    style={\"description_width\": \"initial\"},\n)\napply_btn = widgets.Button(description=\"Apply\")\nclose_btn = widgets.Button(description=\"Close\")\noutput_widget = widgets.Output()\nwith output_widget:\n    print(\"Draw a polygon on the map. Then, \\nclick on the 'Apply' button\")","key":"HXJqNeNlML"},{"type":"outputs","id":"hWbDO9oz4-qpy5YoU0yP-","children":[],"key":"b9MTKqhm4i"}],"key":"pOSIhxWKwI"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"children":[{"type":"text","value":"Implementing the Query Logic","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"bCoEnfGUeP"}],"identifier":"implementing-the-query-logic","label":"Implementing the Query Logic","html_id":"implementing-the-query-logic","implicit":true,"key":"Fz9lp7n2pz"}],"key":"bciu7QjOId"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def on_apply_btn_click(change):\n    with output_widget:\n        try:\n            output_widget.clear_output()\n            if len(m.draw_features_selected) > 0:\n                geojson = m.draw_features_selected[0][\"geometry\"]\n            df = con.sql(\n                f\"\"\"\n            SELECT * EXCLUDE (geometry), ST_AsText(geometry) AS geometry FROM h3_res4_geo\n            WHERE ST_Intersects(geometry, ST_GeomFromGeoJSON('{json.dumps(geojson)}'));\n            \"\"\"\n            ).df()\n            gdf = leafmap.df_to_gdf(df)\n            if \"H3 Hexagon\" in m.layer_dict:\n                m.remove_layer(\"H3 Hexagon\")\n\n            if outline_chk.value:\n                outline_color = \"rgba(255, 255, 255, 255)\"\n            else:\n                outline_color = \"rgba(255, 255, 255, 0)\"\n\n            if checkbox.value:\n                m.add_data(\n                    gdf,\n                    column=\"building_count\",\n                    scheme=\"JenksCaspall\",\n                    cmap=colormap_dropdown.value,\n                    k=class_slider.value,\n                    outline_color=outline_color,\n                    name=\"H3 Hexagon\",\n                    before_id=m.first_symbol_layer_id,\n                    extrude=True,\n                    fit_bounds=False,\n                    add_legend=False,\n                )\n            else:\n                m.add_data(\n                    gdf,\n                    column=\"building_count\",\n                    scheme=\"JenksCaspall\",\n                    cmap=colormap_dropdown.value,\n                    k=class_slider.value,\n                    outline_color=outline_color,\n                    name=\"H3 Hexagon\",\n                    before_id=m.first_symbol_layer_id,\n                    fit_bounds=False,\n                    add_legend=False,\n                )\n\n            m.remove_from_sidebar(name=\"Legend\")\n            m.add_legend_to_sidebar(\n                title=\"Building Count\",\n                legend_dict=m.legend_dict,\n            )\n        except Exception as e:\n            with output_widget:\n                print(e)\n\n\ndef on_close_btn_click(change):\n    m.remove_from_sidebar(name=\"H3 Hexagonal Grid\")","key":"YgSwLIxiDq"},{"type":"outputs","id":"iGmruAc_HJGuSZ5qf6iC5","children":[],"key":"Lv5HlPUU1o"}],"key":"lgq8hA1StY"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":210,"column":1},"end":{"line":210,"column":1}},"children":[{"type":"text","value":"Wiring Up the Interface","position":{"start":{"line":210,"column":1},"end":{"line":210,"column":1}},"key":"g31fKOZymB"}],"identifier":"wiring-up-the-interface","label":"Wiring Up the Interface","html_id":"wiring-up-the-interface","implicit":true,"key":"S3TysgX4Uk"}],"key":"kY07cl0Gy3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"apply_btn.on_click(on_apply_btn_click)\nclose_btn.on_click(on_close_btn_click)\n\nwidget = widgets.VBox(\n    [\n        widgets.HBox([checkbox, outline_chk]),\n        colormap_dropdown,\n        class_slider,\n        widgets.HBox([apply_btn, close_btn]),\n        output_widget,\n    ]\n)\nm.add_to_sidebar(widget, label=\"H3 Hexagonal Grid\", widget_icon=\"mdi-hexagon-multiple\")","key":"EeViCOC5IG"},{"type":"outputs","id":"fvsoR4AQ0ePbQNeVlEK58","children":[],"key":"fXhpQhWJkP"}],"key":"IG9lE3LDHO"},{"type":"block","children":[{"type":"heading","depth":4,"position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"children":[{"type":"text","value":"How Voilà Transforms This Notebook","position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"key":"Si8IpBbK7F"}],"identifier":"how-voil-transforms-this-notebook","label":"How Voilà Transforms This Notebook","html_id":"how-voil-transforms-this-notebook","implicit":true,"key":"aCGsmx5RoX"},{"type":"heading","depth":3,"position":{"start":{"line":230,"column":1},"end":{"line":230,"column":1}},"children":[{"type":"text","value":"Exploring the File Structure of the Space","position":{"start":{"line":230,"column":1},"end":{"line":230,"column":1}},"key":"ScDdxE5J5i"}],"identifier":"exploring-the-file-structure-of-the-space","label":"Exploring the File Structure of the Space","html_id":"exploring-the-file-structure-of-the-space","implicit":true,"key":"OWbZWHu4X5"},{"type":"heading","depth":3,"position":{"start":{"line":232,"column":1},"end":{"line":232,"column":1}},"children":[{"type":"text","value":"Updating the Hugging Face Space","position":{"start":{"line":232,"column":1},"end":{"line":232,"column":1}},"key":"D7UGKJDoma"}],"identifier":"updating-the-hugging-face-space","label":"Updating the Hugging Face Space","html_id":"updating-the-hugging-face-space","implicit":true,"key":"oFuNiIdcqQ"},{"type":"heading","depth":4,"position":{"start":{"line":234,"column":1},"end":{"line":234,"column":1}},"children":[{"type":"text","value":"Updating the Space from the Hu