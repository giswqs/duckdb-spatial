ate\", \"Area_SqKm\", height=900, title=\"Wetland Area by State\"\n)","key":"spg2NOX3mm"},{"type":"outputs","id":"3mS_Hus9dq_P_bMDDhHLb","children":[],"key":"zq7fMDxSOg"}],"key":"NfnfSolftm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.bar_chart(area_df, \"State\", \"Area_SqKm\", title=\"Wetland Area by State\")","key":"kfbxaXUljX"},{"type":"outputs","id":"IeMXMaZYSafTPSVnu-boU","children":[],"key":"UhGNAhZOBp"}],"key":"hhgKhM092H"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":325,"column":1},"end":{"line":325,"column":1}},"children":[{"type":"text","value":"Classification by Wetland Type","position":{"start":{"line":325,"column":1},"end":{"line":325,"column":1}},"key":"VRCV9xSCTk"}],"identifier":"classification-by-wetland-type","label":"Classification by Wetland Type","html_id":"classification-by-wetland-type","implicit":true,"key":"Arnj3zwVNs"}],"key":"s2phl6MhvI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"type_df = con.sql(\n    f\"\"\"\nSELECT WETLAND_TYPE,\n       COUNT(*) AS count,\n       ROUND(SUM(Shape_Area) / 1e6, 0) AS area_sqkm\nFROM 's3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet'\nGROUP BY WETLAND_TYPE\nORDER BY area_sqkm DESC\n\"\"\"\n).df()\ntype_df.head(10)","key":"NskohITl05"},{"type":"outputs","id":"rf4UrVotRHUFySxI1MW65","children":[],"key":"g6rLPvHXZS"}],"key":"wrI9LeU43M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"by_state_type = con.sql(\n    f\"\"\"\nSELECT SUBSTRING(filename, LENGTH(filename) - 18, 0) AS State,\n       WETLAND_TYPE,\n       ROUND(SUM(Shape_Area) / 1e6, 2) AS area_sqkm\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY State, WETLAND_TYPE\nQUALIFY ROW_NUMBER() OVER (PARTITION BY State ORDER BY area_sqkm D