:1}},"key":"n1QFrCjd1T"}],"identifier":"environment-setup-and-extension-loading","label":"Environment Setup and Extension Loading","html_id":"environment-setup-and-extension-loading","implicit":true,"key":"DkS4wTVL8K"}],"key":"mvFN2trOXL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# %pip install duckdb leafmap","key":"CJxGTiJedH"},{"type":"outputs","id":"sQgkxnuAwGR2nSPO5GI2N","children":[],"key":"BIOKdwDtFQ"}],"key":"fz4dnRMXQo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import duckdb\n\n# Create an in-memory DuckDB connection\ncon = duckdb.connect()\n\n# Install and load the spatial extension for geometry operations\ncon.install_extension(\"spatial\")\ncon.load_extension(\"spatial\")","key":"vJRNWsbvem"},{"type":"outputs","id":"pCzDuoFg0hoJb-fn_1j9o","children":[],"key":"zXiix4kcMz"}],"key":"vvxslh1fL0"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Querying a Single State’s Wetlands","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"uRvUN5eINJ"}],"identifier":"querying-a-single-states-wetlands","label":"Querying a Single State’s Wetlands","html_id":"querying-a-single-states-wetlands","implicit":true,"key":"L1ArPxsF2o"}],"key":"mxjNYrvXED"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Select a state to analyze (DC has a manageable dataset size for initial exploration)\nstate = \"DC\"  # You can change this to any two-letter state code like \"FL\", \"CA\", \"TX\"\n\n# Construct the URL to the GeoParquet file hosted on Source Cooperative\nurl = f\"https://data.source.coop/giswqs/nwi/wetlands/{state}_Wetlands.parquet\"\n\n# Query the wetland data directly from cloud storage\n# DuckDB automatically handles the HTTPS connection and Parquet parsing\ncon.sql(f\"SELECT * FROM '{url}'\")","key":"UGCZQnfERo"},{"type":"outputs","id":"ys19scaAm9YueGA4OVvLl","children":[],"key":"kiqav6hAu7"}],"key":"IiXgxqgrD9"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"Inspecting the Data Schema","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"fsSHjgiKfI"}],"identifier":"inspecting-the-data-schema","label":"Inspecting the Data Schema","html_id":"inspecting-the-data-schema","implicit":true,"key":"kwVAuJMdTs"}],"key":"tbg26vkV3B"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(f\"DESCRIBE SELECT * FROM '{url}'\")","key":"Zpl22SXys6"},{"type":"outputs","id":"CIXSO7wVN712tx3VtSFxF","children":[],"key":"l0p9PPeStm"}],"key":"sA3LnsHqwi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(f\"SELECT DISTINCT WETLAND_TYPE FROM '{url}'\")","key":"FNNtF8JrhR"},{"type":"outputs","id":"oqtRby9fd4HXNcm3ZCmOs","children":[],"key":"tzJVWBoLVV"}],"key":"aS21ayXfB4"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Alternative Access Methods","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"swKWIRPeVz"}],"identifier":"alternative-access-methods","label":"Alternative Access Methods","html_id":"alternative-access-methods","implicit":true,"key":"DK7OKHs8c2"},{"type":"code","lang":"bash","value":"aws s3 ls s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/","position":{"start":{"line":80,"column":1},"end":{"line":82,"column":1}},"key":"p8tO4TffdF"},{"type":"code","lang":"bash","value":"aws s3 ls s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/ --recursive --summarize | grep \"Total Size\" | awk '{print $3/1024/1024/1024 \" GB\"}'","position":{"start":{"line":84,"column":1},"end":{"line":86,"column":1}},"key":"XSJtF4BLzH"},{"type":"heading","depth":2,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Visualizing Wetland Distributions","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"PXOb3NomQs"}],"identifier":"visualizing-wetland-distributions","label":"Visualizing Wetland Distributions","html_id":"visualizing-wetland-distributions","implicit":true,"key":"knZxEutF89"},{"type":"heading","depth":3,"position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"Loading and Preparing State-Level Data","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"buoYrplNcj"}],"identifier":"loading-and-preparing-state-level-data","label":"Loading and Preparing State-Level Data","html_id":"loading-and-preparing-state-level-data","implicit":true,"key":"oKaq73IDJ5"}],"key":"ioBzQZyUpS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import leafmap.maplibregl as leafmap","key":"XF6Vdfts8L"},{"type":"outputs","id":"zJJiEXI1gkwjjYxNBjDBM","children":[],"key":"PIn2E9y31K"}],"key":"feTOaRdIlz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"state = \"DC\"  # Washington DC has a manageable dataset size for visualization\nurl = f\"https://data.source.coop/giswqs/nwi/wetlands/{state}_Wetlands.parquet\"\n\n# Read the Parquet file from cloud storage and convert to a GeoDataFrame\n# src_crs='EPSG:5070' specifies the Albers Equal Area Conic projection (used in NWI data)\n# dst_crs='EPSG:4326' reprojects to WGS84 latitude/longitude (required for web mapping)\n# return_type='gdf' ensures we get a GeoPandas GeoDataFrame with spatial capabilities\ngdf = leafmap.read_vector(\n    url, return_type=\"gdf\", src_crs=\"EPSG:5070\", dst_crs=\"EPSG:4326\"\n)\n\n# Display basic statistics about the loaded dataset\nprint(f\"Number of wetland features: {len(gdf):,}\")\nprint(f\"Unique wetland types: {gdf['WETLAND_TYPE'].nunique()}\")\nprint(f\"Total wetland area: {gdf['Shape_Area'].sum() / 1_000_000:.2f} sq km\")","key":"px3uWB3tVN"},{"type":"outputs","id":"XFFseH6nWtyDK6V0mr6es","children":[],"key":"ll1i4JEBlF"}],"key":"Z49JR30CBN"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"Creating Thematic Visualizations by Wetland Type","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"tMebtS1fm5"}],"identifier":"creating-thematic-visualizations-by-wetland-type","label":"Creating Thematic Visualizations by Wetland Type","html_id":"creating-thematic-visualizations-by-wetland-type","implicit":true,"key":"Q8Om2nVXCM"}],"key":"ZBCI2eoXR5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a new interactive map centered on the data\nm = leafmap.Map()\n\n# Add a high-resolution satellite imagery basemap for context\n# This helps identify wetland relationships with land use and landscape features\nm.add_basemap(\"Esri.WorldImagery\")\n\n# Define colors for each wetland type using RGB values\ncolor_map = {\n    \"Freshwater Forested/Shrub Wetland\": (0, 136, 55),  # Dark green\n    \"Freshwater Emergent Wetland\": (127, 195, 28),  # Bright green\n    \"Freshwater Pond\": (104, 140, 192),  # Light blue\n    \"Estuarine and Marine Wetland\": (102, 194, 165),  # Teal\n    \"Riverine\": (1, 144, 191),  # Medium blue\n    \"Lake\": (19, 0, 124),  # Dark blue\n    \"Estuarine and Marine Deepwater\": (0, 124, 136),  # Deep teal\n    \"Other\": (178, 134, 86),  # Brown\n}\n\n\n# Helper function to convert RGB tuples to RGBA strings with transparency\ndef rgba(rgb, a=0.85):\n    r, g, b = rgb\n    return f\"rgba({r},{g},{b},{a})\"\n\n\n# Build a MapLibre GL style expression for conditional coloring\n# The \"match\" expression looks up each feature's WETLAND_TYPE and applies the corresponding color\nfill_match = [\"match\", [\"get\", \"WETLAND_TYPE\"]]\nfor wetland_type, color in color_map.items():\n    fill_match += [wetland_type, rgba(color)]\n# Add a default gray color for any wetland types not in our color map\nfill_match += [\"rgba(200,200,200,0.6)\"]\n\n# Define the paint properties for the wetland polygons\npaint = {\n    \"fill-color\": fill_match,  # Apply conditional colors\n    \"fill-outline-color\": \"rgba(0,0,0,0.25)\",  # Subtle dark outlines\n}\n\n# Add the wetland GeoDataFrame to the map as filled polygons\nm.add_vector(gdf, layer_type=\"fill\", paint=paint, name=\"Wetlands\")\n\n# Add a legend explaining the color scheme\nm.add_legend(builtin_legend=\"NWI\", title=\"Wetland Type\")\n\n# Display the map\nm","key":"aK1nPqSKbJ"},{"type":"outputs","id":"X-9ve0NsMPxWhna7KITGt","children":[],"key":"QOhHnPMWJH"}],"key":"rAxxg0YWmy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Alternative simplified approach using leafmap's built-in NWI styling\nm = leafmap.Map()\nm.add_basemap(\"Esri.WorldImagery\")\nm.add_nwi(gdf, name=\"Wetlands\")\nm.add_legend(builtin_legend=\"NWI\", title=\"Wetland Type\")\nm","key":"NhCUrL6M43"},{"type":"outputs","id":"cejJvf8evRVx_XrKVneHy","children":[],"key":"CLglZt73P3"}],"key":"aESin4U4K9"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"text","value":"National-Scale Wetland Analysis","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"n7jqJmkmgg"}],"identifier":"national-scale-wetland-analysis","label":"National-Scale Wetland Analysis","html_id":"national-scale-wetland-analysis","implicit":true,"key":"p17sn8eN0l"},{"type":"heading","depth":3,"position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"Counting All Wetland Features Nationally","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"f9NVm1f3Ir"}],"identifier":"counting-all-wetland-features-nationally","label":"Counting All Wetland Features Nationally","html_id":"counting-all-wetland-features-nationally","implicit":true,"key":"UZSZGliSFH"}],"key":"e1UjiYD0F9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    f\"\"\"\nSELECT COUNT(*) AS Count\nFROM 's3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet'\n\"\"\"\n)","key":"MMHHkM6R0V"},{"type":"outputs","id":"4_Fe3UQlzSUrlUBmNn9Xd","children":[],"key":"lA7NOVo0jl"}],"key":"oj0490Svw3"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"children":[{"type":"text","value":"Analyzing Wetlands by State","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"key":"LjjBO1YHLL"}],"identifier":"analyzing-wetlands-by-state","label":"Analyzing Wetlands by State","html_id":"analyzing-wetlands-by-state","implicit":true,"key":"nFSDgc5Q5w"}],"key":"EAFUBL71Tn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = con.sql(\n    f\"\"\"\nSELECT filename, COUNT(*) AS Count\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY filename\nORDER BY COUNT(*) DESC;\n\"\"\"\n).df()\ndf.head()","key":"SIoglVYXsl"},{"type":"outputs","id":"5XG5SbCE37bvjh8t5eSG8","children":[],"key":"TxzRKOufBA"}],"key":"fHxNa3oRfy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df[\"filename\"].tolist()","key":"ZhIsugP3Lh"},{"type":"outputs","id":"TgfZqM1RW-Y-pnVEhHR7I","children":[],"key":"lc6r2jdDDq"}],"key":"WNofSOBcXg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"count_df = con.sql(\n    f\"\"\"\nSELECT SUBSTRING(filename, LENGTH(filename) - 18, 2) AS State, COUNT(*) AS Count\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY State\nORDER BY COUNT(*) DESC;\n\"\"\"\n).df()\ncount_df.head(10)","key":"HXkhLHv0Pt"},{"type":"outputs","id":"WcMYr7Hp84ziXtCF3gB8t","children":[],"key":"U7cwRq1prk"}],"key":"SfhA9l4jW6"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Creating Tables for Spatial Joins","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"zqcNdu3tiK"}],"identifier":"creating-tables-for-spatial-joins","label":"Creating Tables for Spatial Joins","html_id":"creating-tables-for-spatial-joins","implicit":true,"key":"SojCOUQ67H"}],"key":"llpWuGeblk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"CREATE OR REPLACE TABLE wetlands AS FROM count_df\")\ncon.sql(\"FROM wetlands\")","key":"PXGpTE9qFD"},{"type":"outputs","id":"e8CgH-FYjZDWKPxBo0vem","children":[],"key":"Q8Sa0AmP3S"}],"key":"z1mbpAPjtt"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"children":[{"type":"text","value":"Loading State Boundaries for Mapping","position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"key":"Pz8MFD9KqN"}],"identifier":"loading-state-boundaries-for-mapping","label":"Loading State Boundaries for Mapping","html_id":"loading-state-boundaries-for-mapping","implicit":true,"key":"djZ39wWCZC"}],"key":"ilClChCzPU"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://data.gishub.org/us/us_states.parquet\"\ncon.sql(\n    f\"\"\"\nCREATE OR REPLACE TABLE states AS\nSELECT * FROM '{url}'\n\"\"\"\n)\ncon.sql(\"FROM states\")","key":"UHtA9sAOVf"},{"type":"outputs","id":"T7tSwlWU-211PZiMMPvCL","children":[],"key":"vfFhOSQtZF"}],"key":"M5tZcrVtL4"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"children":[{"type":"text","value":"Joining Wetland Statistics with State Geometries","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"key":"h4gmkRzDFg"}],"identifier":"joining-wetland-statistics-with-state-geometries","label":"Joining Wetland Statistics with State Geometries","html_id":"joining-wetland-statistics-with-state-geometries","implicit":true,"key":"t3uLg5vbqp"}],"key":"T3OIZlfNWR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT * FROM states INNER JOIN wetlands ON states.id = wetlands.State\n\"\"\"\n)","key":"hjOxdCjzYM"},{"type":"outputs","id":"-R_hbZr_8Q0MS0xYdrhlH","children":[],"key":"fpC8GCI8F7"}],"key":"eNITgPAm6Q"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":249,"column":1},"end":{"line":249,"column":1}},"children":[{"type":"text","value":"Preparing Data for Visualization","position":{"start":{"line":249,"column":1},"end":{"line":249,"column":1}},"key":"sFSW5T4CNG"}],"identifier":"preparing-data-for-visualization","label":"Preparing Data for Visualization","html_id":"preparing-data-for-visualization","implicit":true,"key":"wUx2vlBhBD"}],"key":"tTY9VBE32p"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = con.sql(\n    \"\"\"\nSELECT name, State, Count, ST_AsText(geometry) as geometry\nFROM states INNER JOIN wetlands ON states.id = wetlands.State\n\"\"\"\n).df()\ndf.head()","key":"xdA6Wevbjw"