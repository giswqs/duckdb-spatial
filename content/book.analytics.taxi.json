"code","lang":"python","executable":true,"value":"con.sql(\"SELECT * FROM trips LIMIT 10\")","key":"MwUY6J4QeL"},{"type":"outputs","id":"sjwHUonjS_6IbAAxbGL1i","children":[],"key":"C9LHtNWke7"}],"key":"xTF2FlDSgf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    COUNT(*) as total_trips,\n    MIN(tpep_pickup_datetime) as earliest_trip,\n    MAX(tpep_pickup_datetime) as latest_trip,\n    ROUND(AVG(trip_distance), 2) as avg_distance_miles,\n    ROUND(AVG(total_amount), 2) as avg_total_amount\nFROM trips\n\"\"\"\n)","key":"wPBRZnVtdj"},{"type":"outputs","id":"hvmCgas1uxEfdzimDg1ZG","children":[],"key":"FZu17TgVPm"}],"key":"Xj5MuHZalE"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"Temporal Analysis","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"CnCnSzwnaf"}],"identifier":"temporal-analysis","label":"Temporal Analysis","html_id":"temporal-analysis","implicit":true,"key":"bAWqLxCOzX"},{"type":"heading","depth":3,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Trips by Hour of Day","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"PaxI631OMZ"}],"identifier":"trips-by-hour-of-day","label":"Trips by Hour of Day","html_id":"trips-by-hour-of-day","implicit":true,"key":"lwLdBHkhdh"}],"key":"v0C6ovnXM6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"hourly_trips = con.sql(\n    \"\"\"\nSELECT\n    EXTRACT(HOUR FROM tpep_pickup_datetime) as hour,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nGROUP BY hour\nORDER BY hour\n\"\"\"\n).df()\nhourly_trips","key":"Mpa9vVHuLZ"},{"type":"outputs","id":"ubYChzIOEHhlWuWThctBu","children":[],"key":"lysaBf1R5D"}],"key":"YIGpUEMbcY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = leafmap.line_chart(\n    hourly_trips,\n    x=\"hour\",\n    y=\"trip_count\",\n    title=\"NYC Taxi Trips by Hour of Day\",\n    x_label=\"Hour of Day\",\n    y_label=\"Number of Trips\",\n)\nfig","key":"vt1qGHJ4hc"},{"type":"outputs","id":"RxP3_Hge-WbPqHchvi_55","children":[],"key":"bhVWOFbGuk"}],"key":"gwxU8WNvJ4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig.write_image(\"taxi-hourly-trips.png\", width=1000, height=400, scale=2)","key":"t56q8yVJ2d"},{"type":"outputs","id":"zxRQaInQ11LNcYtEYzXDR","children":[],"key":"vSgLjW19Zj"}],"key":"NbMrHVFnFl"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"Trips by Day of Week","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"mMNbIWMvYH"}],"identifier":"trips-by-day-of-week","label":"Trips by Day of Week","html_id":"trips-by-day-of-week","implicit":true,"key":"YrSW9KHbRH"}],"key":"X8GLyYiddJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"daily_trips = con.sql(\n    \"\"\"\nSELECT\n    DAYNAME(tpep_pickup_datetime) as day_name,\n    DAYOFWEEK(tpep_pickup_datetime) as day_num,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nGROUP BY day_name, day_num\nORDER BY day_num\n\"\"\"\n).df()\ndaily_trips","key":"HCxlNFK9zU"},{"type":"outputs","id":"1cqlptggAehqPPBrO_T33","children":[],"key":"RPMFoEPjFj"}],"key":"Ni70YLpIYF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.bar_chart(\n    daily_trips,\n    x=\"day_name\",\n    y=\"trip_count\",\n    title=\"NYC Taxi Trips by Day of Week\",\n    x_label=\"Day of Week\",\n    y_label=\"Number of Trips\",\n    sort_column=\"day_num\",\n    descending=False,\n)","key":"SWZB8zdAG7"},{"type":"outputs","id":"VOP2h_fb_loAGN9Vwio3T","children":[],"key":"khEvSd3Uhk"}],"key":"pPxXMMXYSK"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"children":[{"type":"text","value":"Peak vs Off-Peak Analysis","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"key":"yr0XxSWKzk"}],"identifier":"peak-vs-off-peak-analysis","label":"Peak vs Off-Peak Analysis","html_id":"peak-vs-off-peak-analysis","implicit":true,"key":"gtRijB5DMQ"}],"key":"m2mfjnHW8Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"time_period_analysis = con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 6 AND 9 THEN 'Morning Rush (6-9 AM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 16 AND 19 THEN 'Evening Rush (4-7 PM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 10 AND 15 THEN 'Midday (10 AM-3 PM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 20 AND 23 THEN 'Evening (8-11 PM)'\n        ELSE 'Night/Early Morning'\n    END as time_period,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    ROUND(AVG(trip_distance / NULLIF(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 3600, 0)), 2) as avg_speed_mph,\nFROM trips\nWHERE tpep_dropoff_datetime > tpep_pickup_datetime\nGROUP BY time_period\nORDER BY trip_count DESC\n\"\"\"\n).df()\ntime_period_analysis","key":"l3yPv46WPu"},{"type":"outputs","id":"WZUZM1zIgAXXWooqRAuBp","children":[],"key":"YJdtTsxEHc"}],"key":"TiYFhXWfN0"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":"Loading Taxi Zone Lookup Data","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"key":"LZR8QLxl5Z"}],"identifier":"loading-taxi-zone-lookup-data","label":"Loading Taxi Zone Lookup Data","html_id":"loading-taxi-zone-lookup-data","implicit":true,"key":"fNvUq7RV3g"}],"key":"Wo4EPrzlzZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load taxi zone boundaries from CloudFront\ntaxi_zone_url = \"https://d37ci6vzurychx.cloudfront.net/misc/taxi_zones.zip\"\ntaxi_zones_gdf = leafmap.read_vector(taxi_zone_url)\n\n# Display first few zones to understand the structure\ntaxi_zones_gdf.head()","key":"V5XilJyodb"},{"type":"outputs","id":"W1nnwgZ-3gBX3BqWAqiDj","children":[],"key":"MsXGhfsqEw"}],"key":"SZMvnVf60r"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the structure and coordinate reference system\nprint(f\"Number of zones: {len(taxi_zones_gdf)}\")\nprint(f\"Coordinate Reference System: {taxi_zones_gdf.crs}\")\nprint(f\"Columns: {list(taxi_zones_gdf.columns)}\")","key":"v6CCYCTgVU"},{"type":"outputs","id":"ZQfG5hD4TBJcb5pnzgWKe","children":[],"key":"cIXFYlL2Vh"}],"key":"mF8qF26fcb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"taxi_zones_gdf = taxi_zones_gdf.to_crs(\"EPSG:4326\")\ntaxi_zones_gdf[\"centroid_lon\"] = taxi_zones_gdf.geometry.centroid.x\ntaxi_zones_gdf[\"centroid_lat\"] = taxi_zones_gdf.geometry.centroid.y\ntaxi_zones_df = taxi_zones_gdf.drop(columns=[\"geometry\"])\ntaxi_zones_df.head()","key":"M1TFe82rpG"},{"type":"outputs","id":"hMC96-njIMNvjGuHJ5uCu","children":[],"key":"lr1p2ETEgh"}],"key":"qNGu9e7r4h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nCREATE OR REPLACE TABLE taxi_zones AS\nSELECT LocationID, borough, zone, centroid_lon, centroid_lat\nFROM taxi_zones_df\nORDER BY LocationID\n\"\"\"\n)\ncon.sql(\"SELECT * FROM taxi_zones LIMIT 5\")","key":"sDTqxOwICD"},{"type":"outputs","id":"gSIFT7tWQg0OH88Z_DDQr","children":[],"key":"hgaYDT9jMZ"}],"key":"WJ1J5XvdaB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"taxi_zones_gdf.explore(column=\"borough\", cmap=\"tab10\")","key":"UE4e7088vq"},{"type":"outputs","id":"RAX2M1JuUcDoy7Jy633un","children":[],"key":"mOK97Kk0rq"}],"key":"h5ijyC8b25"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Spatial Analysis","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"qgOPLIS4Gf"}],"identifier":"spatial-analysis","label":"Spatial Analysis","html_id":"spatial-analysis","implicit":true,"key":"O9IvpiwJAG"},{"type":"heading","depth":3,"position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"children":[{"type":"text","value":"Pickup Location Hotspots","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"key":"gwLsxcCGI2"}],"identifier":"pickup-location-hotspots","label":"Pickup Location Hotspots","html_id":"pickup-location-hotspots","implicit":true,"key":"V0h2VOb6az"}],"key":"yhuE4IX0a5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pickup_hotspots = con.sql(\n    \"\"\"\nSELECT\n    t.PULocationID,\n    z.zone as zone_name,\n    z.borough as borough,\n    COUNT(*) as pickup_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    z.centroid_lon,\n    z.centroid_lat\nFROM trips t\nJOIN taxi_zones z ON t.PULocationID = z.LocationID\nGROUP BY t.PULocationID, z.zone, z.borough, z.centroid_lon, z.centroid_lat\nORDER BY pickup_count DESC\nLIMIT 50\n\"\"\"\n).df()\npickup_hotspots.head(5)","key":"G3iGhUGyp8"},{"type":"outputs","id":"EdLGAuJLD9korDt2IXmoh","children":[],"key":"OUa7LvVxy4"}],"key":"uyddFFxcTG"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":245,"column":1},"end":{"line":245,"column":1}},"children":[{"type":"text","value":"Trip Distance Distribution","position":{"start":{"line":245,"column":1},"end":{"line":245,"column":1}},"key":"d5sDAqLOa2"}],"identifier":"trip-distance-distribution","label":"Trip Distance Distribution","html_id":"trip-distance-distribution","implicit":true,"key":"MYpmlmcDWp"}],"key":"odZznIWfLQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"distance_analysis = con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN trip_distance < 1 THEN 'Very Short (<1 mi)'\n        WHEN trip_distance < 2 THEN 'Short (1-2 mi)'\n        WHEN trip_distance < 5 THEN 'Medium (2-5 mi)'\n        WHEN trip_distance < 10 THEN 'Long (5-10 mi)'\n        ELSE 'Very Long (>10 mi)'\n    END as distance_category,\n    COUNT(*) as trip_count,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nWHERE trip_distance > 0\nGROUP BY distance_category\nORDER BY MIN(trip_distance)\n\"\"\"\n).df()\ndistance_analysis","key":"bouRNJmlZS"},{"type":"outputs","id":"-qw0XRPB8spwxeQ8CuojZ","children":[],"key":"AKHEGL6ZzT"}],"key":"sfEBwyMSDl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(\n    distance_analysis,\n    values=\"trip_count\",\n    names=\"distance_category\",\n    title=\"Distribution of Trip Distances\",\n)","key":"j03qvsn5LL"},{"type":"outputs","id":"KQmfSEPM36Ofb_cLs7Isi","children":[],"key":"B0Yx3LoLN3"}],"key":"GMfmxTDSuE"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":279,"column":1},"end":{"line":279,"column":1}},"children":[{"type":"text","value":"Geographic Distribution Using H3","position":{"start":{"line":279,"column":1},"end":{"line":279,"column":1}},"key":"yH4vzauKba"}],"identifier":"geographic-distribution-using-h3","label":"Geographic Distribution Using H3","html_id":"geographic-distribution-using-h3","implicit":true,"key":"MsHwZXBi6F"}],"key":"exUXFxhQsE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Install H3 extension\ncon.install_extension(\"h3\", repository=\"community\")\ncon.load_extension(\"h3\")","key":"kf7Ot6IGQl"},{"type":"outputs","id":"ZQsCnG91lI6ctwR-mNnbk","children":[],"key":"tagUlTQVys"}],"key":"Got00Xh76j"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"SELECT * FROM taxi_zones\")","key":"NslNHroz20"},{"type":"outputs","id":"iuurTulEaAJLyVD8DeE1L","children":[],"key":"hMKDvMKTUR"}],"key":"Eco3zn9oCq"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Aggregate pickups to H3 hexagons (resolution 8) using zone centroids\nh3_pickups_df = con.sql(\n    \"\"\"\nSELECT\n    h3_latlng_to_cell(z.centroid_lat, z.centroid_lon, 8) as h3_index,\n    COUNT(*) as pickup_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    COUNT(DISTINCT t.PULocationID) as num_zones,\n    h3_cell_to_boundary_wkt(h3_index) as geometry\nFROM trips t\nJOIN taxi_zones z ON t.PULocationID = z.LocationID\nGROUP BY h3_index\nHAVING COUNT(*) > 50\nORDER BY pickup_count DESC\n\"\"\"\n).df()\nh3_pickups_df","key":"sVKGhdvTeg"},{"type":"outputs","id":"7K2ZiPbk3Deq2InhXYGjb","children":[],"key":"SgqUR8u26Y"}],"key":"n5Ebj71Pyj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"h3_pickups_gdf = leafmap.df_to_gdf(h3_pickups_df)","key":"hIKjErAYKY"},{"type":"outputs","id":"jX9O2G9hwMpSIz5xo7eOx","children":[],"key":"eYN5Opp3Ba"}],"key":"EtQNd7nACC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map()\nm.add_data(h3_pickups_gdf, \"pickup_count\", cmap=\"Reds\", zoom_to_layer=True)\nm","key":"VXzCRC1XnT"},{"type":"outputs","id":"F8tE99bq8DEe2tD62TlfO","children":[],"key":"yHJYBVtkaU"}],"key":"Ctolw2yBb1"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":322,"column":1},"end":{"line":322,"column":1}},"children":[{"type":"text","value":"Trip Flow Analysis","position":{"start":{"line":322,"column":1},"end":{"line":322,"column":1}},"key":"gi01BYoaRW"}],"identifier":"trip-flow-analysis","label":"Trip Flow Analysis","html_id":"trip-flow-analysis","implicit":true,"key":"yB59j7OBoP"},{"type":"heading","depth":3,"position":{"start":{"line":324,"column":1},"end":{"line":324,"column":1}},"children":[{"type":"text","value":"Top Origin-Destination Pairs","position":{"start":{"line":324,"column":1},"end":{"line":324,"column":1}},"key":"haMCuV5OqR"}],"identifier":"top-origin-destination-pairs","label":"Top Origin-Destination Pairs","html_id":"top-origin-destination-pairs","implicit":true,"key":"jktmgtObX4"}],"key":"VTcgL2OafE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Analyze common origin-destination pairs using taxi zones\nod_pairs = con.sql(\n    \"\"\"\nSELECT\n    t.PULocationID as origin_zone_id,\n    zo.zone as origin_zone_name,\n    zo.borough as origin_borough,\n    t.DOLocationID as dest_zone_id,\n    zd.zone as dest_zone_name,\n    zd.borough as dest_borough,\n    COUNT(*) as trip_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    ROUND(AVG(EXTRACT(EPOCH FROM (t.tpep_dropoff_datetime - t.tpep_pickup_datetime)) / 60), 1) as avg_duration_min\nFROM trips t\nJOIN taxi_zones zo ON t.PULocationID = zo.LocationID\nJOIN taxi_zones zd ON t.DOLocationID = zd.LocationID\nWHERE t.tpep_dropoff_datetime > t.tpep_pickup_datetime\nGROUP BY t.PULocationID, zo.zone, zo.Borough, t.DOLocationID, zd.zone, zd.Borough\nHAVING COUNT(*) > 100\nORDER BY trip_count DESC\nLIMIT 50\n\"\"\"\n).df()\n\nod_pairs.head(20)","key":"zeCye3hG6c"},{"type":"outputs","id":"ux6VQWLvxEwqQNVhy321B","children":[],"key":"h0LQY11iGs"}],"key":"Qjq9DikFl2"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"children":[{"type":"text","value":"Airport Trips Analysis","position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"key":"JQn9HUXOA8"}],"identifier":"airport-trips-analysis","label":"Airport Trips Analysis","html_id":"airport-trips-analysis","implicit":true,"key":"J8KXPeG3PX"}],"key":"Ad7CLqh40Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE RatecodeID\n        WHEN 1 THEN 'Standard Rate'\n        WHEN 2 THEN 'JFK Airport'\n        WHEN 3 THEN 'Newark Airport'\n        WHEN 4 THEN 'Nassau/Westchester'\n        WHEN 5 THEN 'Negotiated Fare'\n        WHEN 6 THEN 'Group Ride'\n        ELSE 'Unknown'\n    END as trip_type,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    ROUND(AVG(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 60), 1) as avg_duration_min\nFROM trips\nGROUP BY trip_type\nORDER BY trip_count DESC\n\"\"\"\n).show()","key":"J5Wvd2aRHg"},{"type":"outputs","id":"6TWt183m9rbZCX7jE5Upm","children":[],"key":"PCuvIleFq7"}],"key":"fp1BSCLe6p"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(airport_trips, values=\"trip_count\", names=\"trip_type\", title=\"Trip Types by Rate Code\")","key":"g0RACQ1GGP"},{"type":"outputs","id":"8iSMXMQg6T2NxHzYBFUVS","children":[],"key":"PcoPStY1Dk"}],"key":"F1Cax4mfsY"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":385,"column":1},"end":{"line":385,"column":1}},"children":[{"type":"text","value":"Payment and Economic Analysis","position":{"start":{"line":385,"column":1},"end":{"line":385,"column":1}},"key":"f4RObhJkOE"}],"identifier":"payment-and-economic-analysis","label":"Payment and Economic Analysis","html_id":"payment-and-economic-analysis","implicit":true,"key":"kYv2skr4WE"},{"type":"heading","depth":3,"position":{"start":{"line":387,"column":1},"end":{"line":387,"column":1}},"children":[{"type":"text","value":"Payment Type Analysis","position":{"start":{"line":387,"column":1},"end":{"line":387,"column":1}},"key":"vKRPQe1ttn"}],"identifier":"payment-type-analysis","label":"Payment Type Analysis","html_id":"payment-type-analysis","implicit":true,"key":"d488F8aCPs"}],"key":"RMB7Jc6PWj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE payment_type\n        WHEN 1 THEN 'Credit Card'\n        WHEN 2 THEN 'Cash'\n        WHEN 3 THEN 'No Charge'\n        WHEN 4 THEN 'Dispute'\n        ELSE 'Unknown'\n    END as payment_method,\n    COUNT(*) as trip_count,\n    ROUND(AVG(fare_amount), 2) as avg_fare,\n    ROUND(AVG(tip_amount), 2) as avg_tip,\n    ROUND(AVG(total_amount), 2) as avg_total,\n    ROUND(AVG(tip_amount) / NULLIF(AVG(fare_amount), 0) * 100, 1) as avg_tip_percentage,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE fare_amount > 0\nGROUP BY payment_method\nORDER BY trip_count DESC\n\"\"\"\n).show()","key":"ZxxtdlNnJO"},{"type":"outputs","id":"2A91g392Mu2xRBIEU127-","children":[],"key":"ZIkOFBMSBA"}],"key":"n0PCzQeEQ1"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":414,"column":1},"end":{"line":414,"column":1}},"children":[{"type":"text","value":"Tipping Patterns","position":{"start":{"line":414,"column":1},"end":{"line":414,"column":1}},"key":"pAnKAsLCR6"}],"identifier":"tipping-patterns","label":"Tipping Patterns","html_id":"tipping-patterns","implicit":true,"key":"vIYSBD9lvc"}],"key":"oBAw9Fe5dR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN trip_distance < 2 THEN 'Short (<2 mi)'\n        WHEN trip_distance < 5 THEN 'Medium (2-5 mi)'\n        WHEN trip_distance < 10 THEN 'Long (5-10 mi)'\n        ELSE 'Very Long (>10 mi)'\n    END AS distance_category,\n    COUNT(*) AS trip_count,\n    ROUND(AVG(tip_amount), 2) AS avg_tip,\n    ROUND(AVG(tip_amount / NULLIF(fare_amount, 0)) * 100, 1) AS avg_tip_percentage,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE payment_type = 1  -- Credit card only\n  AND fare_amount > 0\n  AND tip_amount >= 0\nGROUP BY distance_category\nORDER BY MIN(trip_distance)\n\"\"\"\n).show()","key":"QbmJ14tqZq"},{"type":"outputs","id":"Y18p4pZoePbm3GSW1PN4X","children":[],"key":"snw7DNwGvw"}],"key":"mNxrEYVHNS"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":440,"column":1},"end":{"line":440,"column":1}},"children":[{"type":"text","value":"Fare per Mile Analysis","position":{"start":{"line":440,"column":1},"end":{"line":440,"column":1}},"key":"HaN6MSUXoy"}],"identifier":"fare-per-mile-analysis","label":"Fare per Mile Analysis","html_id":"fare-per-mile-analysis","implicit":true,"key":"PCqKB0UMBN"}],"key":"P1nyB54GI2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fare_analysis = con.sql(\n    \"\"\"\nSELECT\n    EXTRACT(HOUR FROM tpep_pickup_datetime) as hour,\n    COUNT(*) as trip_count,\n    ROUND(AVG(fare_amount / NULLIF(trip_distance, 0)), 2) as avg_fare_per_mile,\n    ROUND(AVG(trip_distance / NULLIF(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 3600, 0)), 2) as avg_speed_mph,\n    ROUND(AVG(total_amount), 2) as avg_total_fare,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE trip_distance > 0\n  AND tpep_dropoff_datetime > tpep_pickup_datetime\n  AND EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) > 60  -- At least 1 minute\nGROUP BY hour\nORDER BY hour\n\"\"\"\n).df()\nfare_analysis","key":"YkIT7xOBsE"},{"type":"outputs","id":"U3MvvjScp0vSumcXkgFPK","children":[],"key":"rna4a5oKZU"}],"key":"wde7LBou6h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.line_chart(fare_analysis, x=\"hour\", y=\"avg_fare_per_mile\", title=\"Average Fare Per Mile by Hour of Day\", x_label=\"Hour of Day\", y_label=\"Average Fare Per Mile\")","key":"LG9XqmzOoz"},{"type":"outputs","id":"cE4ftvg-bi7GnXLlEp5ma","children":[],"key":"gdRVe0Wvr6"}],"key":"YeyXmp0ml4"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":467,"column":1},"end":{"line":467,"column":1}},"children":[{"type":"text","value":"Passenger Behavior Analysis","position":{"start":{"line":467,"column":1},"end":{"line":467,"column":1}},"key":"U6hchX0mpk"}],"identifier":"passenger-behavior-analysis","label":"Passenger Behavior Analysis","html_id":"passenger-behavior-analysis","implicit":true,"key":"QoGSAaUNpM"}],"key":"EXrjiEgpuP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    passenger_count,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_total,\n    ROUND(AVG(total_amount / passenger_count), 2) as avg_per_passenger,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE passenger_count BETWEEN 1 AND 6\nGROUP BY passenger_count\nORDER BY passenger_count\n\"\"\"\n).show()","key":"Go1OdibYV6"},{"type":"outputs","id":"JdbI3U33wYR2zW6Prauhw","children":[],"key":"TLxgXQ97lw"}],"key":"HzwHtBL2TH"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":487,"column":1},"end":{"line":487,"column":1}},"children":[{"type":"text","value":"Multi-Month Analysis","position":{"start":{"line":487,"column":1},"end":{"line":487,"column":1}},"key":"mfwMb1teGB"}],"identifier":"multi-month-analysis","label":"Multi-Month Analysis","html_id":"multi-month-analysis","implicit":true,"key":"V3Vhgbh60k"}],"key":"V4XhKaurPL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"months = range(1, 10)\nmonths_to_analyze = [f\"yellow_tripdata_2025-{month:02d}.parquet\" for month in months]\n\nmonthly_comparison = con.sql(\n    f\"\"\"\nSELECT\n    EXTRACT(YEAR FROM tpep_pickup_datetime) as year,\n    EXTRACT(MONTH FROM tpep_pickup_datetime) as month,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    SUM(total_amount) as total_revenue,\nFROM read_parquet([{','.join([f\"'https://d37ci6vzurychx.cloudfront.net/trip-data/{m}'\" for m in months_to_analyze])}])\nWHERE year = 2025\nGROUP BY year, month\nORDER BY year, month\n\"\"\"\n).df()\n\nmonthly_comparison","key":"CR5XE20ccu"},{"type":"outputs","id":"klB7NTuGz_YslCcCgyuJk","children":[],"key":"slLnQj0x2B"}],"key":"Mu4NFSpL7U"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Visualize monthly trends\nmonthly_comparison[\"month_label\"] = monthly_comparison.apply(\n    lambda x: f\"{int(x['year'])}-{int(x['month']):02d}\", axis=1\n)\n\nleafmap.bar_chart(monthly_comparison, x=\"month_label\",     y=\"trip_count\",\n    title=\"Monthly Taxi Trip Volume\", x_label=\"Month\", y_label=\"Number of Trips\" )","key":"zQXEterw7k"},{"type":"outputs","id":"V4Eh5My9bpsDyquaJJHo8","children":[],"key":"kLOhkH94NH"}],"key":"aakxbuMAEA"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":522,"column":1},"end":{"line":522,"column":1}},"children":[{"type":"text","value":"Visualization","position":{"start":{"line":522,"column":1},"end":{"line":522,"column":1}},"key":"VuhsMZQ0FB"}],"identifier":"visualization","label":"Visualization","html_id":"visualization","implicit":true,"key":"ayxXsg04A6"},{"type":"heading","depth":3,"position":{"start":{"line":524,"column":1},"end":{"line":524,"column":1}},"children":[{"type":"text","value":"Aggregating Trip Data by Zone","position":{"start":{"line":524,"column":1},"end":{"line":524,"column":1}},"key":"VidGg56saT"}],"identifier":"aggregating-trip-data-by-zone","label":"Aggregating Trip Data by Zone","html_id":"aggregating-trip-data-by-zone","implicit":true,"key":"EWyEfMLqy2"}],"key":"hYxmsmOf74"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pickup_df = con.sql(\n    \"\"\"\n    SELECT PULocationID, COUNT(*) as pickup_count\n    FROM trips\n    GROUP BY PULocationID\n    \"\"\"\n).df()\npickup_df","key":"gxduHMsVXP"},{"type":"outputs","id":"5RPU0NzwlQ5eEFS8vMyxO","children":[],"key":"RPK5P6FypF"}],"key":"iIM2GFOMoY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dropoff_df = con.sql(\n    \"\"\"\n    SELECT DOLocationID, COUNT(*) as dropoff_count\n    FROM trips\n    GROUP BY DOLocationID\n    \"\"\"\n).df()\ndropoff_df","key":"rbPMyLk7eo"},{"type":"outputs","id":"RAiY9ODbOpNzt4e1sDH0v","children":[],"key":"pakHt6wKt0"}],"key":"tBePsSa1Dn"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":548,"column":1},"end":{"line":548,"column":1}},"children":[{"type":"text","value":"Merging with Geographic Data","position":{"start":{"line":548,"column":1},"end":{"line":548,"column":1}},"key":"PFBSKshn9Y"}],