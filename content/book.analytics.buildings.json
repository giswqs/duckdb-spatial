:"neighbors_df[\"h3_cell\"] = neighbors_df[\"h3_cell\"].astype(str)\nneighbors_df = neighbors_df.merge(h3_res4_gdf, on=\"h3_cell\", how=\"left\")\nneighbors_df[\"geometry\"] = neighbors_df[\"geometry\"].astype(str)\nneighbors_gdf = leafmap.df_to_gdf(neighbors_df, src_crs=\"EPSG:4326\")\nneighbors_gdf","key":"gVInsy9PuY"},{"type":"outputs","id":"GQ2CsstJCUKQotACyz2ow","children":[],"key":"MxQFWuSy0O"}],"key":"R3JnM2cFoa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"neighbors_gdf.explore(column=\"building_count\", cmap=\"inferno\")","key":"lD1SAZqh9h"},{"type":"outputs","id":"nUCd2_8-zgGYosNqkDmbD","children":[],"key":"CvH2bAnF7u"}],"key":"xrYTpkCedH"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":685,"column":1},"end":{"line":685,"column":1}},"children":[{"type":"text","value":"When to Use H3 vs. Other Aggregation Methods","position":{"start":{"line":685,"column":1},"end":{"line":685,"column":1}},"key":"lgR5e3mUxp"}],"identifier":"when-to-use-h3-vs-other-aggregation-methods","label":"When to Use H3 vs. Other Aggregation Methods","html_id":"when-to-use-h3-vs-other-aggregation-methods","implicit":true,"key":"intCQrylS9"},{"type":"heading","depth":2,"position":{"start":{"line":687,"column":1},"end":{"line":687,"column":1}},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":687,"column":1},"end":{"line":687,"column":1}},"key":"AV0UFJRoJv"}],"identifier":"key-takeaways","label":"Key Takeaways","html_id":"key-takeaways","implicit":true,"key":"uImDav8mWY"},{"type":"heading","depth":2,"position":{"start":{"line":689,"column":1},"end":{"line":689,"column":1}},"children":[{"type":"text","value":"Exercises","position":{"start":{"line":689,"column":1},"end":{"line":689,"column":1}},"key":"eQaQDRqRri"}],"identifier":"exercises","label":"Exercises","html_id":"exercises","implicit":true,"key":"NdC8d2o1Ta"},{"type":"heading","depth":3,"position":{"start"