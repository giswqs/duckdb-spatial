"},{"type":"outputs","id":"eoJSMSR94VSuiDZz8ijvm","children":[],"key":"nXZKmIyN0X"}],"key":"k8lJpNS1Nt"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Exploring Available Data","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"ZmjWGBTYfr"}],"identifier":"exploring-available-data","label":"Exploring Available Data","html_id":"exploring-available-data","implicit":true,"key":"h2l3lcchzx"},{"type":"heading","depth":3,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Understanding the Dataset Scale","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"eBkmDX7MNP"}],"identifier":"understanding-the-dataset-scale","label":"Understanding the Dataset Scale","html_id":"understanding-the-dataset-scale","implicit":true,"key":"fGt1HGyK5J"}],"key":"w4s7zuKQhE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"release = leafmap.get_overture_latest_release(patch=True)\nprint(release)","key":"o4hAGSCbMx"},{"type":"outputs","id":"sk6qNO68wrVZMEK9PuIeV","children":[],"key":"acJnzfi6H6"}],"key":"IRBtoM7dd1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = f\"s3://overturemaps-us-west-2/release/{release}/theme=buildings/type=building/*.parquet\"","key":"eZmQC9eScv"},{"type":"outputs","id":"s4UGfWgRC7CxS5SNunmjB","children":[],"key":"sAlsxoYFzz"}],"key":"C4yuT68WOY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Examine the first few records to understand the schema\ncon.sql(\n    f\"\"\"\nSELECT *\nFROM read_parquet('{url}')\nLIMIT 10\n\"\"\"\n)","key":"vOwoi8dzU0"},{"type":"outputs","id":"jFLa7-X0dVd3gM2nniCWU","children":[],"key":"L0d4FXmTzE"}],"key":"Um445UwcPt"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"children":[{"type":"text","value":"Counting the Complete Dataset","position":{"start":{"line":66,"column":1},"end":{"line":66,"column":1}},"key":"Zemp6yYXm2"}],"identifier":"counting-the-complete-dataset","label":"Counting the Complete Dataset","html_id":"counting-the-complete-dataset","implicit":true,"key":"PhkLs7gbxe"}],"key":"MYRl1Qu2S1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    f\"\"\"\nSELECT COUNT(*) as count\nFROM read_parquet('{url}')\n\"\"\"\n)","key":"xA4gEK1S5y"},{"type":"outputs","id":"tnwd4XqdLCsV4_4lmPuyr","children":[],"key":"J5IL4RBwTs"}],"key":"OUqQoSQ4Ka"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"Visualizing Buildings in 3D","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"XKx0yL8IEz"}],"identifier":"visualizing-buildings-in-3d","label":"Visualizing Buildings in 3D","html_id":"visualizing-buildings-in-3d","implicit":true,"key":"k374r5zkzO"}],"key":"mQT9x8V8Rw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map(\n    center=[-74.009789, 40.709945], zoom=14.65, pitch=60, bearing=-17, style=\"positron\"\n)\nm.add_basemap(\"OpenStreetMap.Mapnik\")\nm.add_basemap(\"Esri.WorldImagery\", visible=False)\nm.add_overture_3d_buildings(\n    values=[0, 200, 400], colors=[\"lightgray\", \"royalblue\", \"lightblue\"]\n)\nm","key":"CBjoGK8RN8"},{"type":"outputs","id":"-aCwUZbrVSu_6iPA2M_Xh","children":[],"key":"Tirmoxyg28"}],"key":"fb7FHdezUh"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"Regional Analysis with Bounding Box Filtering","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"LHA4xIByeb"}],"identifier":"regional-analysis-with-bounding-box-filtering","label":"Regional Analysis with Bounding Box Filtering","html_id":"regional-analysis-with-bounding-box-filtering","implicit":true,"key":"upj5kMb6CR"},{"type":"heading","depth":3,"position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"Loading Regional Data with Spatial Filters","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"kXC9b069bx"}],"identifier":"loading-regional-data-with-spatial-filters","label":"Loading Regional Data with Spatial Filters","html_id":"loading-regional-data-with-spatial-filters","implicit":true,"key":"YmScOjvot7"}],"key":"KChz5EkKw8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Define bounding box for Colorado (approximate)\nmin_lon, max_lon = -109.1, -102.0\nmin_lat, max_lat = 37.0, 41.0\n\n# Create a table for the region's buildings\ncon.sql(\n    f\"\"\"\nCREATE TABLE IF NOT EXISTS buildings AS\nSELECT\n    id,\n    geometry,\n    bbox,\n    height,\n    num_floors,\n    class,\n    sources,\n    REPLACE(CAST(sources->0->'dataset' as VARCHAR), '\"', '') as source,\n    ROUND(ST_Area(ST_Transform(geometry, 'EPSG:4326', 'EPSG:32613', true)), 2) as area_sq_meters\nFROM read_parquet('{url}')\nWHERE bbox.xmin >= {min_lon} AND bbox.xmax <= {max_lon}\n  AND bbox.ymin >= {min_lat} AND bbox.ymax <= {max_lat}\n\"\"\"\n)","key":"UFcZrVw2Z3"},{"type":"outputs","id":"dDyF1ICiXI4diEUEJ3xws","children":[],"key":"dq6xuNP6ua"}],"key":"OF1RBUExJP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"FROM buildings LIMIT 10\")","key":"DUWSBKj2uB"},{"type":"outputs","id":"nRM_0TnoRNZ38L_pNWjv4","children":[],"key":"M2asorvs9b"}],"key":"hQOishBPFu"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},"children":[{"type":"text","value":"Exporting Regional Data","position":{"start":{"line":125,"column":1},"end":{"line":125,"column":1}},"key":"wqRDHcP6Rn"}],"identifier":"exporting-regional-data","label":"Exporting Regional Data","html_id":"exporting-regional-data","implicit":true,"key":"RIYWTESJ31"}],"key":"jZmz9sLV19"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"COPY buildings TO 'buildings.parquet'\")","key":"EfcCKY6Nu3"},{"type":"outputs","id":"uBRL_lGuXDAqMSL1olEKz","children":[],"key":"ajzPIDtlIa"}],"key":"NhojEiCHxT"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"text","value":"Basic Statistics","position":{"start":{"line":131,"column":1},"end":{"line":131,"column":1}},"key":"LEJbHX7YWd"}],"identifier":"basic-statistics","label":"Basic Statistics","html_id":"basic-statistics","implicit":true,"key":"calMPPlo7x"}],"key":"wYgBVzk6AA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Count total buildings in Colorado\ncon.sql(\"SELECT COUNT(*) as total_buildings FROM buildings\")","key":"Qdg4jFDd3D"},{"type":"outputs","id":"xDtvUV_dcR3WuP39e7m-k","children":[],"key":"Wpaz8C5eTS"}],"key":"BFMsYm28bM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Calculate comprehensive area statistics\ncon.sql(\n    \"\"\"\nSELECT\n    COUNT(*) as building_count,\n    ROUND(SUM(area_sq_meters) / 1000000, 2) as total_area_sq_km,\n    ROUND(AVG(area_sq_meters), 2) as avg_building_area,\n    ROUND(MIN(area_sq_meters), 2) as min_area,\n    ROUND(MAX(area_sq_meters), 2) as max_area,\n    ROUND(MEDIAN(area_sq_meters), 2) as median_area\nFROM buildings\n\"\"\"\n)","key":"z8Ofk0WojY"},{"type":"outputs","id":"aBwRmAMw2UPlFVi9-aRKw","children":[],"key":"tvKgeo9XMK"}],"key":"kKXCGNVFpl"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":154,"column":1},"end":{"line":154,"column":1}},"children":[{"type":"text","value":"Building Size Distribution","position":{"start":{"line":154,"column":1},"end":{"line":154,"column":1}},"key":"p8D3JWO7yw"}],"identifier":"building-size-distribution","label":"Building Size Distribution","html_id":"building-size-distribution","implicit":true,"key":"UyQzpOv1fV"}],"key":"s7mh7dWw85"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Categorize buildings by size\ncon.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN area_sq_meters < 50 THEN 'Small (<50 m²)'\n        WHEN area_sq_meters < 100 THEN 'Medium (50-100 m²)'\n        WHEN area_sq_meters < 200 THEN 'Large (100-200 m²)'\n        ELSE 'Very Large (>200 m²)'\n    END as size_category,\n    COUNT(*) as count,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage\nFROM buildings\nGROUP BY size_category\nORDER BY MIN(area_sq_meters)\n\"\"\"\n)","key":"BglrFPMayZ"},{"type":"outputs","id":"AemrnYXl358LoVa4JxJnb","children":[],"key":"Wm78QpA5Ct"}],"key":"PiOEHGDS0N"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"text","value":"Spatial Sampling and Visualization","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"aOeH4myOK3"}],"identifier":"spatial-sampling-and-visualization","label":"Spatial Sampling and Visualization","html_id":"spatial-sampling-and-visualization","implicit":true,"key":"LRtl2fqDyF"}],"key":"WlaxZ0Zyai"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Sample 10,000 buildings for visualization\nsample_gdf = con.sql(\n    \"\"\"\nSELECT area_sq_meters, ST_AsText(geometry) as geometry\nFROM buildings\nUSING SAMPLE 10000\n\"\"\"\n).df()\n\n# Convert to GeoDataFrame\ngdf = leafmap.df_to_gdf(sample_gdf, src_crs=\"EPSG:4326\")","key":"jt8oDSyjgF"},{"type":"outputs","id":"R6JSmBTWGp-Q09BpuYIJe","children":[],"key":"hJAp726OQh"}],"key":"hCJR2n0uBa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Visualize the building sample\nm = leafmap.Map(center=[-104.978833, 39.740018], zoom=12)\nm.add_data(\n    gdf, column=\"area_sq_meters\", cmap=\"RdYlGn\", legend_title=\"Building Area (m²)\", fit_bounds=False\n)\nm","key":"xBGdMBOZOR"},{"type":"outputs","id":"qwUecHRJ6rwSxDXLkhcH5","children":[],"key":"Br14fjXf6G"}],"key":"cFwGCF2TtN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.close()","key":"eWBTn0bAui"},{"type":"outputs","id":"EpzannapBj0_-_K5ALLBw","children":[],"key":"IZF0rFgmjY"}],"key":"YqUb8QSpEr"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"children":[{"type":"text","value":"Visualizing Buildings Directly from DuckDB","position":{"start":{"line":205,"column":1},"end":{"line":205,"column":1}},"key":"lS4usNPZU3"}],"identifier":"visualizing-buildings-directly-from-duckdb","label":"Visualizing Buildings Directly from DuckDB","html_id":"visualizing-buildings-directly-from-duckdb","implicit":true,"key":"w5foZspVvo"}],"key":"jbbdqvXiXy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map(\n    center=[-104.991531, 39.742043], zoom=14, style=\"positron\", height=\"600px\"\n)\nm.add_basemap(\"Esri.WorldImagery\")\nm.add_duckdb_layer(\n    database_path=\"buildings.db\",\n    table_name=\"buildings\",\n    geom_column=\"geometry\",\n    layer_name=\"Buildings\",\n    layer_type=\"fill\",\n    paint={\"fill-color\": \"#3388ff\", \"fill-outline-color\": \"#ffffff\"},\n    opacity=0.5,\n    fit_bounds=False,\n    src_crs=\"EPSG:4326\",\n    quiet=False,\n)\nm","key":"NV1xmio3ed"},{"type":"outputs","id":"069Ay9WY6kg5WcBHJeE3d","children":[],"key":"Zkg8HQGhMS"}],"key":"Ew5OK7hHIr"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":227,"column":1},"end":{"line":227,"column":1}},"children":[{"type":"text","value":"Data-Driven Styling by Building Area","position":{"start":{"line":227,"column":1},"end":{"line":227,"column":1}},"key":"W4PQXyx04q"}],"identifier":"data-driven-styling-by-building-area","label":"Data-Driven Styling by Building Area","html_id":"data-driven-styling-by-building-area","implicit":true,"key":"EQ3O4NwmeM"}],"key":"kK9vRGqamr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map(\n    center=[-104.991531, 39.742043], zoom=14, style=\"positron\", height=\"600px\"\n)\nm.add_basemap(\"Esri.WorldImagery\")\n\npaint = {\n    \"fill-color\": [\n        \"interpolate\",\n        [\"linear\"],\n        [\"get\", \"area_sq_meters\"],\n        0,\n        \"#000004\",\n        50,\n        \"#781c6d\",\n        100,\n        \"#ed6925\",\n        200,\n        \"#fcffa4\",\n    ],\n}\nm.add_duckdb_layer(\n    database_path=\"buildings.db\",\n    table_name=\"buildings\",\n    geom_column=\"geometry\",\n    layer_name=\"Buildings\",\n    layer_type=\"fill\",\n    paint=paint,\n    opacity=0.8,\n    fit_bounds=False,\n    src_crs=\"EPSG:4326\",\n    quiet=False,\n)\nlegend_dict = {\n    \"Small (<50 m²)\": \"#000004\",\n    \"Medium (50-100 m²)\": \"#781c6d\",\n    \"Large (100-200 m²)\": \"#ed6925\",\n    \"Very Large (>200 m²)\": \"#fcffa4\",\n}\nm.add_legend(title=\"Build Category\", legend_dict=legend_dict)\nm","key":"QT1VKlmNAN"},{"type":"outputs","id":"Y1Fv4X-NFR94zR94twW6Y","children":[],"key":"bmPhxmke0m"}],"key":"NFUeYPuDdI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m.close_db_connections()","key":"ud9VMMy6s5"},{"type":"outputs","id":"bjgseT_MygiDcoW1A7-hj","children":[],"key":"XUMlcLMM4N"}],"key":"d39BM15PdS"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":276,"column":1},"end":{"line":276,"column":1}},"children":[{"type":"text","value":"Multi-Region Comparison","position":{"start":{"line":276,"column":1},"end":{"line":276,"column":1}},"key":"Ok0SR0ESuM"}],"identifier":"multi-region-comparison","label":"Multi-Region Comparison","html_id":"multi-region-comparison","implicit":true,"key":"iLrYMqwd6U"},{"type":"heading","depth":3,"position":{"start":{"line":278,"column":1},"end":{"line":278,"column":1}},"children":[{"type":"text","value":"Setting Up Multi-County Analysis","position":{"start":{"line":278,"column":1},"end":{"line":278,"column":1}},"key":"VcyePemS85"}],"identifier":"setting-up-multi-county-analysis","label":"Setting Up Multi-County Analysis","html_id":"setting-up-multi-county-analysis","implicit":true,"key":"L1Eij5wMEB"}],"key":"POWUBlhvzW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con = duckdb.connect()\ncon.load_extension(\"httpfs\")\ncon.load_extension(\"spatial\")","key":"kfqdgSQcVQ"},{"type":"outputs","id":"2vS_UiNPRuoccmFveQGJm","children":[],"key":"DBBFgd0jsS"}],"key":"ePWVU058nX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"CREATE TABLE buildings AS FROM 'buildings.parquet'\")","key":"rENrPD4TQr"},{"type":"outputs","id":"mgHqO4j5g1PEON_FrMF5_","children":[],"key":"MiOxTXWs7o"}],"key":"YF5DWVBmhV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"DESCRIBE buildings\")","key":"d9wUzBaZV0"},{"type":"outputs","id":"1pxLnxn5kGH26roffYLJP","children":[],"key":"vVU4UWnupD"}],"key":"Led2utKq5s"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":294,"column":1},"end":{"line":294,"column":1}},"children":[{"type":"text","value":"Loading County Boundaries","position":{"start":{"line":294,"column":1},"end":{"line":294,"column":1}},"key":"XaHfeWWdat"}],"identifier":"loading-county-boundaries","label":"Loading County Boundaries","html_id":"loading-county-boundaries","implicit":true,"key":"WaiUoI8XbO"}],"key":"DcY3qoLcRa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load Colorado county boundaries\ncounties_url = \"https://data.gishub.org/us/us_counties.parquet\"\ncounties_gdf = leafmap.read_vector(counties_url)\ncounties_gdf.crs = \"EPSG:4326\"\ncounties_gdf = counties_gdf[counties_gdf[\"STATE\"] == \"08\"]\ncounties_gdf.head()","key":"Klxunp09yN"},{"type":"outputs","id":"xcwJBvqCohcfgW6nu6QZm","children":[],"key":"ZqEIf8o3RZ"}],"key":"ds82YBEu42"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"counties_gdf.explore()","key":"zfzXQpHXVb"},{"type":"outputs","id":"ct_3l90-2E_8TzKT42NpB","children":[],"key":"z221T7vswd"}],"key":"f1Vygf6faR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# First, create a temporary table with county boundaries\ncon.sql(\n\"\"\"\nCREATE OR REPLACE TABLE counties AS\nSELECT\n    NAME as county_name,\n    geometry\nFROM read_parquet('https://data.gishub.org/us/us_counties.parquet')\nWHERE STATE = '08'\n\"\"\"\n)\n\n# Perform spatial join and calculate statistics by county\ncomparison_df = con.sql(\n\"\"\"\nSELECT\n    c.county_name,\n    COUNT(b.*) as building_count,\n    ROUND(SUM(b.area_sq_meters) / 1000000, 2) as total_area_sq_km,\n    ROUND(AVG(b.area_sq_meters), 2) as avg_building_size,\n    ROUND(MEDIAN(b.area_sq_meters), 2) as median_building_size\nFROM buildings b\nJOIN counties c ON ST_Intersects(b.geometry, c.geometry)\nGROUP BY c.county_name\nORDER BY building_count DESC\n\"\"\"\n).df()\ncomparison_df.head()","key":"mLuPOMh7Ko"},{"type":"outputs","id":"5-AgkOznvP41bx6Al9ahs","children":[],"key":"NHB4Te9AzC"}],"key":"zUwnvE95fY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a bar chart comparing building counts for top 20 counties\ntop_counties = comparison_df.head(20)\nleafmap.bar_chart(\n    top_counties,\n    \"county_name\",\n    \"building_count\",\n    x_label=\"County\",\n    y_label=\"Building Count\",\n    title=\"Building Count by County (Top 20)\",\n)","key":"pSjTEkTxu1"},{"type":"outputs","id":"S5bwVRBzVdKKs6mIovCat","children":[],"key":"eXkDSEnYSS"}],"key":"CCIlMcxsBM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Compare average building sizes for top counties\nleafmap.bar_chart(\n    top_counties,\n    \"county_name\",\n    \"avg_building_size\",\n    x_label=\"County\",\n    y_label=\"Average Building Size (m²)\",\n    title=\"Average Building Size by County (m²)\",\n)","key":"R3WHecu6ZB"},{"type":"outputs","id":"WudTMPpHKHLQJzUD_L4mA","children":[],"key":"zsh7FUYTOT"}],"key":"v2X4PuBnIN"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":365,"column":1},"end":{"line":365,"column":1}},"children":[{"type":"text","value":"Data Source Filtering and Quality Assessment","position":{"start":{"line":365,"column":1},"end":{"line":365,"column":1}},"key":"styhUSRB0V"}],"identifier":"data-source-filtering-and-quality-assessment","label":"Data Source Filtering and Quality Assessment","html_id":"data-source-filtering-and-quality-assessment","implicit":true,"key":"o1ORsfkNRT"}],"key":"d3dlGbLVGD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Examine data sources in the buildings\nsource_query = \"\"\"\nSELECT\n    source,\n    COUNT(*) as building_count,\n    ROUND(AVG(area_sq_meters), 2) as avg_area,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage\nFROM buildings\nWHERE sources IS NOT NULL\nGROUP BY source\nORDER BY building_count DESC\n\"\"\"\nsource_df = con.sql(source_query).df()\nsource_df","key":"xMwFInLkfj"},{"type":"outputs","id":"P8Fw2NQnQ8QAjXb2h5NdE","children":[],"key":"vUI9SjBdpi"}],"key":"QXiq6zabCg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(source_df, names=\"source\", values=\"building_count\", title=\"Building Count by Source\")","key":"FnGcKOPF0o"},{"type":"outputs","id":"puwDJzKLJF5qTZ8reDfxa","children":[],"key":"fMiJKyixqy"}],"key":"loDhaA87Ek"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":388,"column":1},"end":{"line":388,"column":1}},"children":[{"type":"text","value":"Filtering by Data Source Quality","position":{"start":{"line":388,"column":1},"end":{"line":388,"column":1}},"key":"y5tLCGEWw9"}],"identifier":"filtering-by-data-source-quality","label":"Filtering by Data Source Quality","html_id":"filtering-by-data-source-quality","implicit":true,"key":"ItmKoLWuXf"}],"key":"LgciaeqL9w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Filter to OSM buildings only\ncon.sql(\n    \"\"\"\nSELECT\n    COUNT(*) as osm_building_count,\n    ROUND(AVG(area_sq_meters), 2) as avg_area,\n    COUNT(CASE WHEN height IS NOT NULL THEN 1 END) as buildings_with_height,\n    COUNT(CASE WHEN num_floors IS NOT NULL THEN 1 END) as buildings_with_floors,\n    COUNT(CASE WHEN class IS NOT NULL THEN 1 END) as buildings_with_class\nFROM buildings\nWHERE source='OpenStreetMap'\n\"\"\"\n).show()","key":"qlhISadQGR"},{"type":"outputs","id":"DyrUV_fvsHEwjf9N0RPvG","children":[],"key":"PBAFxgKX6Z"}],"key":"IHb05yuuTE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.close()","key":"MuxEwdMq5M"},{"type":"outputs","id":"f-C77oAZ_4SzKrhZYZxz1","children":[],"key":"aJjDKtNhJT"}],"key":"UPglWoQOWN"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":410,"column":1},"end":{"line":410,"column":1}},"children":[{"type":"text","value":"Visualizing Data Source Distribution","position":{"start":{"line":410,"column":1},"end":{"line":410,"column":1}},"key":"DrP3nRo506"}],"identifier":"visualizing-data-source-distribution","label":"Visualizing Data Source Distribution","html_id":"visualizing-data-source-distribution","implicit":true,"key":"hXYZHzuNdd"}],"key":"IXzClhtVp0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map(\n    center=[-105.012019, 39.675236], zoom=15, style=\"positron\", height=\"600px\"\n)\nm.add_basemap(\"Esri.WorldImagery\")\n\npaint = {\n    \"fill-color\": [\n        \"case\",\n        [\"==\", [\"get\", \"source\"], \"OpenStreetMap\"],\n        \"#FF0000\",\n        [\"==\", [\"get\", \"source\"], \"Microsoft ML Buildings\"],\n        \"#00FF00\",\n        [\"==\", [\"get\", \"source\"], \"Esri Community Maps\"],\n        \"#0000FF\",\n        \"#000000\",\n    ],\n}\nm.add_duckdb_layer(\n    database_path=\"buildings.db\",\n    table_name=\"buildings\",\n    geom_column=\"geometry\",\n    layer_name=\"Buildings\",\n    layer_type=\"fill\",\n    paint=paint,\n    opacity=0.5,\n    fit_bounds=False,\n    src_crs=\"EPSG:4326\",\n    quiet=False,\n)\nlegend_dict = {\n    \"OpenStreetMap\": \"#FF0000\",\n    \"Microsoft ML Buildings\": \"#00FF00\",\n    \"Esri Community Maps\": \"#0000FF\",\n}\nm.add_legend(title=\"Data Source\", legend_dict=legend_dict)\nm","key":"h9u4chlEfD"},{"type":"outputs","id":"SOqs1r706wLadjgkyqbl_","children":[],"key":"hMRVBPnMQh"}],"key":"nVAyqiXrRn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m.close_db_connections()","key":"zjfatEzCLh"},{"type":"outputs","id":"NxKZXqVb8nu7phLmk7GFy","children":[],"key":"ujZHDp7Rq9"}],"key":"BlwiSqqBQp"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":455,"column":1},"end":{"line":455,"column":1}},"children":[{"type":"text","value":"Grid-Based Spatial Aggregation","position":{"start":{"line":455,"column":1},"end":{"line":455,"column":1}},"key":"cOU5vhb2Ll"}],"identifier":"grid-based-spatial-aggregation","label":"Grid-Based Spatial Aggregation","html_id":"grid-based-spatial-aggregation","implicit":true,"key":"yXnz7RUn04"},{"type":"heading","depth":3,"position":{"start":{"line":457,"column":1},"end":{"line":457,"column":1}},"children":[{"type":"text","value":"Setting Up Grid Analysis","position":{"start":{"line":457,"column":1},"end":{"line":457,"column":1}},"key":"n5oFhVrF9P"}],"identifier":"setting-up-grid-analysis","label":"Setting Up Grid Analysis","html_id":"setting-up-grid-analysis","implicit":true,"key":"LjF2iFKJsX"}],"key":"q0MC1wYE64"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con = duckdb.connect()\ncon.load_extension(\"httpfs\")\ncon.load_extension(\"spatial\")","key":"ffkFUlqNAO"},{"type":"outputs","id":"jzDzmfhRLjSvQT0yD76EC","children":[],"key":"q3SefWHEd5"}],"key":"rzD6O7pYTH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"CREATE TABLE buildings AS FROM 'buildings.parquet'\")","key":"o5T0NTCcOK"},{"type":"outputs","id":"xrRPTi70BGRNa4Yy1X1fb","children":[],"key":"m5aiLKKRdq"}],"key":"LdjVnbsVc9"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":469,"column":1},"end":{"line":469,"column":1}},"children":[{"type":"text","value":"Generating a Regular Grid","position":{"start":{"line":469,"column":1},"end":{"line":469,"column":1}},"key":"k7Vj2K5YdY"}],"identifier":"generating-a-regular-grid","label":"Generating a Regular Grid","html_id":"generating-a-regular-grid","implicit":true,"key":"ywOZ4QFDAc"}],"key":"eNQmOzerzA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"extent = (-109.1, 37.0, -102.0, 41.0)\ngrid = leafmap.generate_latlon_grid(extent, dx=0.1, dy=0.1, output=\"grid.geojson\")\ngrid.head()","key":"nfAjRZQ4dN"},{"type":"outputs","id":"GjJA18zEgyXIG8k7YnGyc","children":[],"key":"U2EN9z6eKX"}],"key":"LUxwWqkhw7"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"print(f\"Number of grid cells: {len(grid)}\")","key":"dsFmMYDGpq"},{"type":"outputs","id":"nF3DeLM9R3DOPOM7ZOICd","children":[],"key":"Yj58bIoO8w"}],"key":"WmFcGyjzXP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"grid.explore()","key":"uVyB2BxV1a"},{"type":"outputs","id":"0d8jxmvOHF9liAjpIyGWi","children":[],"key":"iPjF0zp2Gw"}],"key":"efhRwvVVp0"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":485,"column":1},"end":{"line":485,"column":1}},"children":[{"type":"text","value":"Loading Grid into DuckDB","position":{"start":{"line":485,"column":1},"end":{"line":485,"column":1}},"key":"HQxUwc2WC8"}],"identifier":"loading-grid-into-duckdb","label":"Loading Grid into DuckDB","html_id":"loading-grid-into-duckdb","implicit":true,"key":"FgVjDJhWAh"}],"key":"fhSb1QiiyV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"\"\"\nCREATE OR REPLACE TABLE grid AS\nSELECT * FROM ST_Read('grid.geojson')\n\"\"\")","key":"kY4e8PyRKP"},{"type":"outputs","id":"2eHJczDqftyNW7EAlV0kh","children":[],"key":"qIxDWruBAw"}],"key":"ZiqkBbtWBt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"SHOW TABLES\")","key":"aJ18hOgUgg"},{"type":"outputs","id":"jYIdE1c5JZep8zhgJkJgj","children":[],"key":"Kcec2ZwJqP"}],"key":"W0uSbX8LlV"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":498,"column":1},"end":{"line":498,"column":1}},"children":[{"type":"text","value":"Performing Spatial Aggregation","position":{"start":{"line":498,"column":1},"end":{"line":498,"column":1}},"key":"AaxKkd10uP"}],"identifier":"performing-spatial-aggregation","label":"Performing Spatial Aggregation","html_id":"performing-spatial-aggregation","implicit":true,"key":"IUCnICAgw0"}],"key":"puQmDtwfFG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"\"\"\nCREATE OR REPLACE TABLE grid_building_counts AS\nSELECT\n    g.id,\n    g.lon_min,\n    g.lat_min,\n    g.lon_max,\n    g.lat_max,\n    g.geom,\n    COUNT(b.*) AS building_count\nFROM grid AS g\nLEFT JOIN buildings AS b\n    ON ST_Intersects(g.geom, b.geometry)\nGROUP BY\n    g.id,\n    g.lon_min,\n    g.lat_min,\n    g.lon_max,\n    g.lat_max,\n    g.geom\nORDER BY\n    g.id;\n\"\"\")","key":"r86vCnn3uN"},{"type":"outputs","id":"3xoaJGhwaiZFEU75kaCe0","children":[],"key":"rnB6cNgpgD"}],"key":"uVveBGVMhq"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":526,"column":1},"end":{"line":526,"column":1}},"children":[{"type":"text","value":"Visualizing Grid Aggregation Results","position":{"start":{"line":526,"column":1},"end":{"line":526,"column":1}},"key":"brEhPldyt6"}],"identifier":"visualizing-grid-aggregation-results","label":"Visualizing Grid Aggregation Results","html_id":"visualizing-grid-aggregation-results","implicit":true,"key":"BoBdzIWmM6"}],"key":"BX4ztRqW6I"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"grid_df = con.sql(\"SELECT * EXCLUDE (geom), ST_AsText(geom) AS geometry FROM grid_building_counts\").df()\ngrid_gdf = leafmap.df_to_gdf(grid_df, src_crs=\"EPSG:4326\")\ngrid_gdf.head()","key":"GkR97YfmWM"},{"type":"outputs","id":"oL9uRCJffEZa4P3lGJ_b2","children":[],"key":"hb4K04NbL8"}],"key":"bNUnVkCipl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map()\nm.add_basemap(\"Esri.WorldImagery\", before_id=m.first_symbol_layer_id)\nm.add_data(grid_gdf, column=\"building_count\", cmap=\"inferno\", name=\"Building Count\", before_id=m.first_symbol_layer_id)\nm","key":"Mg8znAufZ5"},{"type":"outputs","id":"KJMMAFuDb7GIeKs21V_W_","children":[],"key":"NcMJs7BS8W"}],"key":"XIHRU4Uxll"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.close()","key":"EhpZrFZY0H"},{"type":"outputs","id":"YF0onq4naiBg9dHQiIeKq","children":[],"key":"GpnsVGWIq6"}],"key":"ygsChRBFgT"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":545,"column":1},"end":{"line":545,"column":1}},"children":[{"type":"text","value":"Aggregating Building Data with H3 Hexagonal Grids","position":{"start":{"line":545,"column":1},"end":{"line":545,"column":1}},"key":"cMgSkPznW5"}],"identifier":"aggregating-building-data-with-h3-hexagonal-grids","label":"Aggregating Building Data with H3 Hexagonal Grids","html_id":"aggregating-building-data-with-h3-hexagonal-grids","implicit":true,"key":"uxEqofDTQ3"},{"type":"heading","depth":3,"position":{"start":{"line":547,"column":1},"end":{"line":547,"column":1}},"children":[{"type":"text","value":"Understanding H3’s Advantages Over Traditional Grids","position":{"start":{"line":547,"column":1},"end":{"line":547,"column":1}},"key":"ReAvZeqsy0"}],"identifier":"understanding-h3s-advantages-over-traditional-grids","label":"Understanding H3’s Advantages Over Traditional Grids","html_id":"understanding-h3s-advantages-over-traditional-grids","implicit":true,"key":"tj7eRl2bK7"},{"type":"heading","depth":3,"position":{"start":{"line":549,"column":1},"end":{"line":549,"column":1}},"children":[{"type":"text","value":"Installing and Loading the H3 Extension","position":{"start":{"line":549,"column":1},"end":{"line":549,"column":1}},"key":"BBp4xVOqcg"}],"identifier":"installing-and-loading-the-h3-extension","label":"Installing and Loading the H3 Extension","html_id":"installing-and-loading-the-h3-extension","implicit":true,"key":"G2h2U3wL6C"}],"key":"XBHsimyiI3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con = duckdb.connect()\ncon.install_extension(\"h3\", repository=\"community\")\ncon.load_extension(\"h3\")","key":"CotjACjiXi"},{"type":"outputs","id":"mGuPHwYkOMeZ9LkUT5hUj","children":[],"key":"NRTkR7Xup7"}],"key":"Ur0ZtmAuto"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.load_extension(\"httpfs\")\ncon.load_extension(\"spatial\")","key":"yTs8cEVFCr"},{"type":"outputs","id":"qjr46nugb-TmxALl2kE1f","children":[],"key":"FECgc3fZRM"}],"key":"KmwmBSb4QI"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":562,"column":1},"end":{"line":562,"column":1}},"children":[{"type":"text","value":"Choosing Appropriate H3 Resolutions","position":{"start":{"line":562,"column":1},"end":{"line":562,"column":1}},"key":"pZCnCDn2Xe"}],"identifier":"choosing-appropriate-h3-resolutions","label":"Choosing Appropriate H3 Resolutions","html_id":"choosing-appropriate-h3-resolutions","implicit":true,"key":"O4eszYnTow"},{"type":"heading","depth":3,"position":{"start":{"line":564,"column":1},"end":{"line":564,"column":1}},"children":[{"type":"text","value":"Creating H3-Based Building Aggregations","position":{"start":{"line":564,"column":1},"end":{"line":564,"column":1}},"key":"VLHVynYkkd"}],"identifier":"creating-h3-based-building-aggregations","label":"Creating H3-Based Building Aggregations","html_id":"creating-h3-based-building-aggregations","implicit":true,"key":"yUHfKqjUsE"}],"key":"ZBuwnq1jDP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Aggregate buildings into H3 resolution 6 hexagons\nh3_res4_query = f\"\"\"\nCREATE TABLE IF NOT EXISTS h3_res4_aggregation AS\nSELECT\n    h3_latlng_to_cell(\n        ST_Y(ST_Centroid(geometry)),\n        ST_X(ST_Centroid(geometry)),\n        4\n    ) as h3_cell,\n    COUNT(*) as building_count,\nFROM read_parquet('{url}')\nWHERE bbox.xmin BETWEEN -178.5 AND 178.5\nGROUP BY h3_cell\nORDER BY building_count DESC\n\"\"\"\n# con.sql(h3_res4_query)","key":"aXS0Kvzy92"},{"type":"outputs","id":"PTCrAIRY6cxGI0xdfZM6a","children":[],"key":"RowC2MdToD"}],"key":"VhcLPLTrNV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"h3_geo_query = f\"\"\"\nCREATE OR REPLACE TABLE h3_res4_geo AS\nSELECT\n    CAST(h3_cell AS VARCHAR) as h3_cell,\n    building_count,\n    ST_GeomFromText(h3_cell_to_boundary_wkt(h3_cell)) as geometry\nFROM h3_res4_aggregation\n\"\"\"\n# con.sql(h3_geo_query)","key":"WmKV4qQBSk"},{"type":"outputs","id":"0FRRmko6h2z3MgGlPgkLu","children":[],"key":"sQUpcFl2eQ"}],"key":"d9RbmFfpr5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"\"\"\nCREATE TABLE IF NOT EXISTS h3_res4_geo AS\nSELECT * FROM 'https://data.gishub.org/duckdb/h3_res4_geo.parquet';\n\"\"\")","key":"xxEBRFDWHB"},{"type":"outputs","id":"P2V72W3BMuzzqIU-kpMTK","children":[],"key":"cY0eA8T7Zv"}],"key":"HdXV9FUScL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"SHOW TABLES\")","key":"IV6xIE2Fcm"},{"type":"outputs","id":"1UaXOnCiGA8RgpYQbfqC8","children":[],"key":"Wwdwt0eCMg"}],"key":"QtQB2ELDvi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"COPY h3_res4_geo TO 'h3_res4_geo.parquet'\")","key":"Q1fSXSgqeY"},{"type":"outputs","id":"AcgHLSE0LbvMkNWN2nch8","children":[],"key":"Ues7PdD5S0"}],"key":"s