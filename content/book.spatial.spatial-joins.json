)\n) AS cities\nON ST_Intersects(neighborhoods.geom, cities.geom);\n\"\"\"\n)","key":"RtkiXfKSss"},{"type":"outputs","id":"sM8QWvOFCrjSdveRkyZk9","children":[],"key":"CeZrOm2VXt"}],"key":"PLbW38zw4o"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":259,"column":1},"end":{"line":259,"column":1}},"children":[{"type":"text","value":"Spatial Relationship Functions Reference","position":{"start":{"line":259,"column":1},"end":{"line":259,"column":1}},"key":"qvCXdoeeKp"}],"identifier":"spatial-relationship-functions-reference","label":"Spatial Relationship Functions Reference","html_id":"spatial-relationship-functions-reference","implicit":true,"key":"iRwRNuprpz"},{"type":"heading","depth":3,"position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"children":[{"type":"text","value":"Core Spatial Predicates","position":{"start":{"line":261,"column":1},"end":{"line":261,"column":1}},"key":"MC2bt1bYxF"}],"identifier":"core-spatial-predicates","label":"Core Spatial Predicates","html_id":"core-spatial-predicates","implicit":true,"key":"QDzE86tTvM"},{"type":"heading","depth":3,"position":{"start":{"line":263,"column":1},"end":{"line":263,"column":1}},"children":[{"type":"text","value":"Choosing the Right Predicate","position":{"start":{"line":263,"column":1},"end":{"line":263,"column":1}},"key":"egnE8UB0PU"}],"identifier":"choosing-the-right-predicate","label":"Choosing the Right Predicate","html_id":"choosing-the-right-predicate","implicit":true,"key":"Q9bt25kKyZ"},{"type":"heading","depth":2,"position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":265,"column":1},"end":{"line":265,"column":1}},"key":"MgEag7HXlk"}],"identifier":"key-takeaways","label":"Key Takeaways","html_id":"key-takeaways","implicit":true,"key":"m4ZynTeZGX"},{"type":"heading","depth":2,"position":{"start":{"line":267,"column":1},"end":{"line":267,"column":1}},