 DISTINCT routes\nFROM nyc_subway_stations AS subways\nWHERE strpos(subways.routes,'A') > 0;\n\"\"\"\n)","key":"E7pI3u7A7R"},{"type":"outputs","id":"JyOaaU9yjRXw5IdqDcGGV","children":[],"key":"tGEvrDflJH"}],"key":"gfVSCKIQpi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n  100.0 * Sum(popn_white) / Sum(popn_total) AS white_pct,\n  100.0 * Sum(popn_black) / Sum(popn_total) AS black_pct,\n  Sum(popn_total) AS popn_total\nFROM nyc_census_blocks AS census\nJOIN nyc_subway_stations AS subways\nON ST_DWithin(census.geom, subways.geom, 200)\nWHERE strpos(subways.routes,'A') > 0;\n\"\"\"\n)","key":"OaVMB83ddN"},{"type":"outputs","id":"eVT5ru5dIHZfv392ZpRRh","children":[],"key":"GWYnhi03x0"}],"key":"ZSxwEcUBo8"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"children":[{"type":"text","value":"Advanced Join","position":{"start":{"line":185,"column":1},"end":{"line":185,"column":1}},"key":"gFhfvIMQFw"}],"identifier":"advanced-join","label":"Advanced Join","html_id":"advanced-join","implicit":true,"key":"iYR5GwZHvq"}],"key":"WRVH5GFrq6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nCREATE OR REPLACE TABLE subway_lines ( route char(1) );\nINSERT INTO subway_lines (route) VALUES\n  ('A'),('B'),('C'),('D'),('E'),('F'),('G'),\n  ('J'),('L'),('M'),('N'),('Q'),('R'),('S'),\n  ('Z'),('1'),('2'),('3'),('4'),('5'),('6'),\n  ('7');\n\"\"\"\n)","key":"yTiqPDlHCF"},{"type":"outputs","id":"ppSKrclWggXeMkqVbvlu5","children":[],"key":"A2vaTFnI0o"}],"key":"VErpuoaT8Y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n  lines.route,\n  100.0 * Sum(popn_white) / Sum(popn_total) AS white_pct,\n  100.0 * Sum(popn_black) / Sum(popn_total) AS black_pct,\n  Sum(popn_total) AS popn_total\nFROM nyc_census_blocks AS census\nJOIN nyc_subway_stations AS subways\nON ST_DWithin(census.geom, subways.geom, 200)\nJOIN subway_lines AS lines\nON strpos(subways.routes, lines.route) > 0\nGROUP BY lines.route\nORDER BY black_pct DESC;\n\"\"\"\n)","key":"TDcv6kA4HU"},{"type":"outputs","id":"VETtY0i5IqaJaH6TPHOl4","children":[],"key":"s9UN4E6Moz"}],"key":"vsjKy92rJT"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Coordinate System Transformations","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"GMpAPcubMN"}],"identifier":"coordinate-system-transformations","label":"Coordinate System Transformations","html_id":"coordinate-system-transformations","implicit":true,"key":"lw0EvL6QQ6"},{"type":"heading","depth":3,"position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"children":[{"type":"text","value":"Transforming Geographic to Projected Coordinates","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"key":"Sjgxu2dEaX"}],"identifier":"transforming-geographic-to-projected-coordinates","label":"Transforming Geographic to Projected Coordinates","html_id":"transforming-geographic-to-projected-coordinates","implicit":true,"key":"bYHdv8fRc2"}],"key":"mtLBkWBXJi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://data.gishub.org/duckdb/cities.parquet\"\ncon.sql(f\"SELECT * FROM '{url}'\")","key":"vrRk2QGYGn"},{"type":"outputs","id":"GH9w5Tx65_J6TetQIwUFI","children":[],"key":"CfmngnawDW"}],"key":"bYmkIIwWGY"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1}},"children":[{"type":"text","value":"Applying the Transformation","position":{"start":{"line":228,"column":1},"end":{"line":228,"column":1