type":"code","lang":"python","executable":true,"value":"con.sql(\"SELECT * FROM trips LIMIT 10\")","key":"pKIjKJl98z"},{"type":"outputs","id":"jfMZRpiPdaj8-pcHSZnqR","children":[],"key":"IbxVfKaPZr"}],"key":"Sd9bomGevP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    COUNT(*) as total_trips,\n    MIN(tpep_pickup_datetime) as earliest_trip,\n    MAX(tpep_pickup_datetime) as latest_trip,\n    ROUND(AVG(trip_distance), 2) as avg_distance_miles,\n    ROUND(AVG(total_amount), 2) as avg_total_amount\nFROM trips\n\"\"\"\n)","key":"CH9qNIMe4X"},{"type":"outputs","id":"Hc7t9vLAXZm42JzqVZUYY","children":[],"key":"dovPDgHy4U"}],"key":"jgrv28brJt"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"Temporal Analysis","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"hGnqAEUErR"}],"identifier":"temporal-analysis","label":"Temporal Analysis","html_id":"temporal-analysis","implicit":true,"key":"nL073J5Dph"},{"type":"heading","depth":3,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"text","value":"Trips by Hour of Day","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"s7H0QaBxBB"}],"identifier":"trips-by-hour-of-day","label":"Trips by Hour of Day","html_id":"trips-by-hour-of-day","implicit":true,"key":"aBTWOqkZ9w"}],"key":"iudqsC8IgB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"hourly_trips = con.sql(\n    \"\"\"\nSELECT\n    EXTRACT(HOUR FROM tpep_pickup_datetime) as hour,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nGROUP BY hour\nORDER BY hour\n\"\"\"\n).df()\nhourly_trips","key":"tqS3UwIXfG"},{"type":"outputs","id":"0ivEYNrTIILOORys9xKPv","children":[],"key":"nXzAwW98iK"}],"key":"aUZbk8VNtR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = leafmap.line_chart(\n    hourly_trips,\n    x=\"hour\",\n    y=\"trip_count\",\n    title=\"NYC Taxi Trips by Hour of Day\",\n    x_label=\"Hour of Day\",\n    y_label=\"Number of Trips\",\n)\nfig","key":"YrFyW9LBsf"},{"type":"outputs","id":"4PsxBpmqhg_aT8DrX4zUE","children":[],"key":"xzKPICdKfA"}],"key":"RUVgSNfJ6Y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig.write_image(\"taxi-hourly-trips.png\", width=1000, height=400, scale=2)","key":"wkNkMkYoA1"},{"type":"outputs","id":"L6njlC4md36rE9mgMg_qS","children":[],"key":"pojXrf5pjo"}],"key":"MM6OXSWeXu"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"text","value":"Trips by Day of Week","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"dz6rLOIIVY"}],"identifier":"trips-by-day-of-week","label":"Trips by Day of Week","html_id":"trips-by-day-of-week","implicit":true,"key":"Xxaal1tD0Y"}],"key":"ertkZGJhx6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"daily_trips = con.sql(\n    \"\"\"\nSELECT\n    DAYNAME(tpep_pickup_datetime) as day_name,\n    DAYOFWEEK(tpep_pickup_datetime) as day_num,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nGROUP BY day_name, day_num\nORDER BY day_num\n\"\"\"\n).df()\ndaily_trips","key":"zVWRF4fjXp"},{"type":"outputs","id":"EZNW_-5faoM3UpkJTK1bH","children":[],"key":"zFgvwU2o3C"}],"key":"cnR72pLeWy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.bar_chart(\n    daily_trips,\n    x=\"day_name\",\n    y=\"trip_count\",\n    title=\"NYC Taxi Trips by Day of Week\",\n    x_label=\"Day of Week\",\n    y_label=\"Number of Trips\",\n    sort_column=\"day_num\",\n    descending=False,\n)","key":"wa9b4ND8fw"},{"type":"outputs","id":"prkJ86exGqm1yE40zxWwE","children":[],"key":"ZPUXWYypjT"}],"key":"MQZhK1EC4v"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"children":[{"type":"text","value":"Peak vs Off-Peak Analysis","position":{"start":{"line":151,"column":1},"end":{"line":151,"column":1}},"key":"SD8K0tWvN5"}],"identifier":"peak-vs-off-peak-analysis","label":"Peak vs Off-Peak Analysis","html_id":"peak-vs-off-peak-analysis","implicit":true,"key":"zkHJt6vOOF"}],"key":"vFew4IWDRB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"time_period_analysis = con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 6 AND 9 THEN 'Morning Rush (6-9 AM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 16 AND 19 THEN 'Evening Rush (4-7 PM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 10 AND 15 THEN 'Midday (10 AM-3 PM)'\n        WHEN EXTRACT(HOUR FROM tpep_pickup_datetime) BETWEEN 20 AND 23 THEN 'Evening (8-11 PM)'\n        ELSE 'Night/Early Morning'\n    END as time_period,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    ROUND(AVG(trip_distance / NULLIF(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 3600, 0)), 2) as avg_speed_mph,\nFROM trips\nWHERE tpep_dropoff_datetime > tpep_pickup_datetime\nGROUP BY time_period\nORDER BY trip_count DESC\n\"\"\"\n).df()\ntime_period_analysis","key":"PY2zK88xaY"},{"type":"outputs","id":"59LuE-csaHXvT5ZTfdjWL","children":[],"key":"byK6nCi3u5"}],"key":"TakVJpApRI"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"children":[{"type":"text","value":"Loading Taxi Zone Lookup Data","position":{"start":{"line":177,"column":1},"end":{"line":177,"column":1}},"key":"tYABYQclQ5"}],"identifier":"loading-taxi-zone-lookup-data","label":"Loading Taxi Zone Lookup Data","html_id":"loading-taxi-zone-lookup-data","implicit":true,"key":"n8KI4jox9H"}],"key":"JgoENt1kKf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load taxi zone boundaries from CloudFront\ntaxi_zone_url = \"https://d37ci6vzurychx.cloudfront.net/misc/taxi_zones.zip\"\ntaxi_zones_gdf = leafmap.read_vector(taxi_zone_url)\n\n# Display first few zones to understand the structure\ntaxi_zones_gdf.head()","key":"QZcL1KUI3H"},{"type":"outputs","id":"BPnzm7T4yTNAI_LXCuvcr","children":[],"key":"er8ceSzBMs"}],"key":"dLsHwJOREV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Check the structure and coordinate reference system\nprint(f\"Number of zones: {len(taxi_zones_gdf)}\")\nprint(f\"Coordinate Reference System: {taxi_zones_gdf.crs}\")\nprint(f\"Columns: {list(taxi_zones_gdf.columns)}\")","key":"AMwIgjDpWF"},{"type":"outputs","id":"eEOXVYNZCZ88R6yThx6oS","children":[],"key":"JnzXkJuqbR"}],"key":"x4bpWOViES"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"taxi_zones_gdf = taxi_zones_gdf.to_crs(\"EPSG:4326\")\ntaxi_zones_gdf[\"centroid_lon\"] = taxi_zones_gdf.geometry.centroid.x\ntaxi_zones_gdf[\"centroid_lat\"] = taxi_zones_gdf.geometry.centroid.y\ntaxi_zones_df = taxi_zones_gdf.drop(columns=[\"geometry\"])\ntaxi_zones_df.head()","key":"smZMJ0bJlT"},{"type":"outputs","id":"LIA4LmydRIe-zAWV-qDyR","children":[],"key":"TUreHF2wZH"}],"key":"cvMCFyDO1r"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nCREATE OR REPLACE TABLE taxi_zones AS\nSELECT LocationID, borough, zone, centroid_lon, centroid_lat\nFROM taxi_zones_df\nORDER BY LocationID\n\"\"\"\n)\ncon.sql(\"SELECT * FROM taxi_zones LIMIT 5\")","key":"xI92nWvnWy"},{"type":"outputs","id":"A6ffn6TTGKwFoThwJPAnz","children":[],"key":"Yzp6q5d9lD"}],"key":"G5B2IpwnSD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"taxi_zones_gdf.explore(column=\"borough\", cmap=\"tab10\")","key":"xpz3tUcwCy"},{"type":"outputs","id":"3sKHkHxoPdOXtM0scKxi0","children":[],"key":"cEF3jLSsBy"}],"key":"r0qvYkKgCD"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Spatial Analysis","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"d9jsJFczcE"}],"identifier":"spatial-analysis","label":"Spatial Analysis","html_id":"spatial-analysis","implicit":true,"key":"iWLVEFaCl1"},{"type":"heading","depth":3,"position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"children":[{"type":"text","value":"Pickup Location Hotspots","position":{"start":{"line":221,"column":1},"end":{"line":221,"column":1}},"key":"wmGHd37rf6"}],"identifier":"pickup-location-hotspots","label":"Pickup Location Hotspots","html_id":"pickup-location-hotspots","implicit":true,"key":"INRAey2qTs"}],"key":"MwtOzP1CLY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pickup_hotspots = con.sql(\n    \"\"\"\nSELECT\n    t.PULocationID,\n    z.zone as zone_name,\n    z.borough as borough,\n    COUNT(*) as pickup_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    z.centroid_lon,\n    z.centroid_lat\nFROM trips t\nJOIN taxi_zones z ON t.PULocationID = z.LocationID\nGROUP BY t.PULocationID, z.zone, z.borough, z.centroid_lon, z.centroid_lat\nORDER BY pickup_count DESC\nLIMIT 50\n\"\"\"\n).df()\npickup_hotspots.head(5)","key":"tUv6VVW0Km"},{"type":"outputs","id":"W8tWFvRejqtfyxChMMhhW","children":[],"key":"q7jHU2rjSv"}],"key":"WNgQaVYpje"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":245,"column":1},"end":{"line":245,"column":1}},"children":[{"type":"text","value":"Trip Distance Distribution","position":{"start":{"line":245,"column":1},"end":{"line":245,"column":1}},"key":"IbftLkEPLj"}],"identifier":"trip-distance-distribution","label":"Trip Distance Distribution","html_id":"trip-distance-distribution","implicit":true,"key":"A1GmNbBs33"}],"key":"frwSLFu9XO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"distance_analysis = con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN trip_distance < 1 THEN 'Very Short (<1 mi)'\n        WHEN trip_distance < 2 THEN 'Short (1-2 mi)'\n        WHEN trip_distance < 5 THEN 'Medium (2-5 mi)'\n        WHEN trip_distance < 10 THEN 'Long (5-10 mi)'\n        ELSE 'Very Long (>10 mi)'\n    END as distance_category,\n    COUNT(*) as trip_count,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\n    ROUND(AVG(total_amount), 2) as avg_fare\nFROM trips\nWHERE trip_distance > 0\nGROUP BY distance_category\nORDER BY MIN(trip_distance)\n\"\"\"\n).df()\ndistance_analysis","key":"tBLSVmzzdJ"},{"type":"outputs","id":"Mr5Y4l5gtfjajni26G_CJ","children":[],"key":"IerqrMbJT1"}],"key":"pK1BhtSX1v"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(\n    distance_analysis,\n    values=\"trip_count\",\n    names=\"distance_category\",\n    title=\"Distribution of Trip Distances\",\n)","key":"TB1IdbpPf2"},{"type":"outputs","id":"Gqhz9-tm6M7Z3rbD8bChd","children":[],"key":"zMJyYPOiJ3"}],"key":"gMoKwwxdjv"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":279,"column":1},"end":{"line":279,"column":1}},"children":[{"type":"text","value":"Geographic Distribution Using H3","position":{"start":{"line":279,"column":1},"end":{"line":279,"column":1}},"key":"Pl6DxXay82"}],"identifier":"geographic-distribution-using-h3","label":"Geographic Distribution Using H3","html_id":"geographic-distribution-using-h3","implicit":true,"key":"SavwqgsoFS"}],"key":"LhdKMtnhIn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Install H3 extension\ncon.install_extension(\"h3\", repository=\"community\")\ncon.load_extension(\"h3\")","key":"jawXNN379O"},{"type":"outputs","id":"vGlhuj8IsZteTIh6vsz4g","children":[],"key":"QLaJSQvsZ8"}],"key":"Nh25h1VcGr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"SELECT * FROM taxi_zones\")","key":"LKilg8nVAy"},{"type":"outputs","id":"B3z3Br6TKTo1ImzbqoiH5","children":[],"key":"Cs96hTUhC6"}],"key":"OPa1MSBaGM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Aggregate pickups to H3 hexagons (resolution 8) using zone centroids\nh3_pickups_df = con.sql(\n    \"\"\"\nSELECT\n    h3_latlng_to_cell(z.centroid_lat, z.centroid_lon, 8) as h3_index,\n    COUNT(*) as pickup_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    COUNT(DISTINCT t.PULocationID) as num_zones,\n    h3_cell_to_boundary_wkt(h3_index) as geometry\nFROM trips t\nJOIN taxi_zones z ON t.PULocationID = z.LocationID\nGROUP BY h3_index\nHAVING COUNT(*) > 50\nORDER BY pickup_count DESC\n\"\"\"\n).df()\nh3_pickups_df","key":"emEbsclvUJ"},{"type":"outputs","id":"XMjnaTQS3H6NM5Jyn05ad","children":[],"key":"LRrFEWfTSb"}],"key":"LCCgg6Kdhr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"h3_pickups_gdf = leafmap.df_to_gdf(h3_pickups_df)","key":"cLFh0yDMc9"},{"type":"outputs","id":"r4xRN6ffbU3YMt1Rbepsq","children":[],"key":"Ja6oy1d5ZA"}],"key":"gc28zNy0lK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"m = leafmap.Map()\nm.add_data(h3_pickups_gdf, \"pickup_count\", cmap=\"Reds\", zoom_to_layer=True)\nm","key":"Pq4kCWDNxT"},{"type":"outputs","id":"WMtuPqFM8K-NE27VZa4Ow","children":[],"key":"lznJR0BGeb"}],"key":"nd8328tWeB"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":322,"column":1},"end":{"line":322,"column":1}},"children":[{"type":"text","value":"Trip Flow Analysis","position":{"start":{"line":322,"column":1},"end":{"line":322,"column":1}},"key":"V7SvXTLxdP"}],"identifier":"trip-flow-analysis","label":"Trip Flow Analysis","html_id":"trip-flow-analysis","implicit":true,"key":"m6Ek7ltx70"},{"type":"heading","depth":3,"position":{"start":{"line":324,"column":1},"end":{"line":324,"column":1}},"children":[{"type":"text","value":"Top Origin-Destination Pairs","position":{"start":{"line":324,"column":1},"end":{"line":324,"column":1}},"key":"NPdJuIMB6b"}],"identifier":"top-origin-destination-pairs","label":"Top Origin-Destination Pairs","html_id":"top-origin-destination-pairs","implicit":true,"key":"wiclDIYjOB"}],"key":"yedWFCQgcR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Analyze common origin-destination pairs using taxi zones\nod_pairs = con.sql(\n    \"\"\"\nSELECT\n    t.PULocationID as origin_zone_id,\n    zo.zone as origin_zone_name,\n    zo.borough as origin_borough,\n    t.DOLocationID as dest_zone_id,\n    zd.zone as dest_zone_name,\n    zd.borough as dest_borough,\n    COUNT(*) as trip_count,\n    ROUND(AVG(t.trip_distance), 2) as avg_distance,\n    ROUND(AVG(t.total_amount), 2) as avg_fare,\n    ROUND(AVG(EXTRACT(EPOCH FROM (t.tpep_dropoff_datetime - t.tpep_pickup_datetime)) / 60), 1) as avg_duration_min\nFROM trips t\nJOIN taxi_zones zo ON t.PULocationID = zo.LocationID\nJOIN taxi_zones zd ON t.DOLocationID = zd.LocationID\nWHERE t.tpep_dropoff_datetime > t.tpep_pickup_datetime\nGROUP BY t.PULocationID, zo.zone, zo.Borough, t.DOLocationID, zd.zone, zd.Borough\nHAVING COUNT(*) > 100\nORDER BY trip_count DESC\nLIMIT 50\n\"\"\"\n).df()\n\nod_pairs.head(20)","key":"uxHd6qvdmf"},{"type":"outputs","id":"dXYTinIZpmhwHakVW5qBd","children":[],"key":"b9kJTUMwN4"}],"key":"vACo9UYSqe"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"children":[{"type":"text","value":"Airport Trips Analysis","position":{"start":{"line":355,"column":1},"end":{"line":355,"column":1}},"key":"S2gLLllYmE"}],"identifier":"airport-trips-analysis","label":"Airport Trips Analysis","html_id":"airport-trips-analysis","implicit":true,"key":"RXghDFBy4r"}],"key":"fQ2ug027wQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE RatecodeID\n        WHEN 1 THEN 'Standard Rate'\n        WHEN 2 THEN 'JFK Airport'\n        WHEN 3 THEN 'Newark Airport'\n        WHEN 4 THEN 'Nassau/Westchester'\n        WHEN 5 THEN 'Negotiated Fare'\n        WHEN 6 THEN 'Group Ride'\n        ELSE 'Unknown'\n    END as trip_type,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    ROUND(AVG(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 60), 1) as avg_duration_min\nFROM trips\nGROUP BY trip_type\nORDER BY trip_count DESC\n\"\"\"\n).show()","key":"kxuwpi7HvH"},{"type":"outputs","id":"tg3beYk3a04DfR1ZizLXf","children":[],"key":"emiGcGZinq"}],"key":"PgcoPqWmb1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(airport_trips, values=\"trip_count\", names=\"trip_type\", title=\"Trip Types by Rate Code\")","key":"NaxBkJvzsV"},{"type":"outputs","id":"DZoD0cadXTou_Yc4WRn4W","children":[],"key":"T89aefOcRk"}],"key":"OUQwfvgNHN"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":385,"column":1},"end":{"line":385,"column":1}},"children":[{"type":"text","value":"Payment and Economic Analysis","position":{"start":{"line":385,"column":1},"end":{"line":385,"column":1}},"key":"M9SeaMyco9"}],"identifier":"payment-and-economic-analysis","label":"Payment and Economic Analysis","html_id":"payment-and-economic-analysis","implicit":true,"key":"KSoJJ7P7xg"},{"type":"heading","depth":3,"position":{"start":{"line":387,"column":1},"end":{"line":387,"column":1}},"children":[{"type":"text","value":"Payment Type Analysis","position":{"start":{"line":387,"column":1},"end":{"line":387,"column":1}},"key":"ycvT25CXxj"}],"identifier":"payment-type-analysis","label":"Payment Type Analysis","html_id":"payment-type-analysis","implicit":true,"key":"JVjbdtw7hg"}],"key":"Y18ioio4lD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE payment_type\n        WHEN 1 THEN 'Credit Card'\n        WHEN 2 THEN 'Cash'\n        WHEN 3 THEN 'No Charge'\n        WHEN 4 THEN 'Dispute'\n        ELSE 'Unknown'\n    END as payment_method,\n    COUNT(*) as trip_count,\n    ROUND(AVG(fare_amount), 2) as avg_fare,\n    ROUND(AVG(tip_amount), 2) as avg_tip,\n    ROUND(AVG(total_amount), 2) as avg_total,\n    ROUND(AVG(tip_amount) / NULLIF(AVG(fare_amount), 0) * 100, 1) as avg_tip_percentage,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE fare_amount > 0\nGROUP BY payment_method\nORDER BY trip_count DESC\n\"\"\"\n).show()","key":"ICysWqSl8v"},{"type":"outputs","id":"WH_qKWl2gFbhQqWXoXdWb","children":[],"key":"JEDY1oD98a"}],"key":"bMDFWd8SR1"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":414,"column":1},"end":{"line":414,"column":1}},"children":[{"type":"text","value":"Tipping Patterns","position":{"start":{"line":414,"column":1},"end":{"line":414,"column":1}},"key":"EL6gbQlBel"}],"identifier":"tipping-patterns","label":"Tipping Patterns","html_id":"tipping-patterns","implicit":true,"key":"P9SvKb0Ntk"}],"key":"dcNvJ4ejgf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    CASE\n        WHEN trip_distance < 2 THEN 'Short (<2 mi)'\n        WHEN trip_distance < 5 THEN 'Medium (2-5 mi)'\n        WHEN trip_distance < 10 THEN 'Long (5-10 mi)'\n        ELSE 'Very Long (>10 mi)'\n    END AS distance_category,\n    COUNT(*) AS trip_count,\n    ROUND(AVG(tip_amount), 2) AS avg_tip,\n    ROUND(AVG(tip_amount / NULLIF(fare_amount, 0)) * 100, 1) AS avg_tip_percentage,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE payment_type = 1  -- Credit card only\n  AND fare_amount > 0\n  AND tip_amount >= 0\nGROUP BY distance_category\nORDER BY MIN(trip_distance)\n\"\"\"\n).show()","key":"jdUJq6HYmm"},{"type":"outputs","id":"iI2njUFJ2cqpY6vBqxFOk","children":[],"key":"W4Z2HSO39h"}],"key":"qvvT1s1wzj"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":440,"column":1},"end":{"line":440,"column":1}},"children":[{"type":"text","value":"Fare per Mile Analysis","position":{"start":{"line":440,"column":1},"end":{"line":440,"column":1}},"key":"huaOHw03NK"}],"identifier":"fare-per-mile-analysis","label":"Fare per Mile Analysis","html_id":"fare-per-mile-analysis","implicit":true,"key":"QxWdwyXOXB"}],"key":"YuEtHUhAJw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fare_analysis = con.sql(\n    \"\"\"\nSELECT\n    EXTRACT(HOUR FROM tpep_pickup_datetime) as hour,\n    COUNT(*) as trip_count,\n    ROUND(AVG(fare_amount / NULLIF(trip_distance, 0)), 2) as avg_fare_per_mile,\n    ROUND(AVG(trip_distance / NULLIF(EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) / 3600, 0)), 2) as avg_speed_mph,\n    ROUND(AVG(total_amount), 2) as avg_total_fare,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE trip_distance > 0\n  AND tpep_dropoff_datetime > tpep_pickup_datetime\n  AND EXTRACT(EPOCH FROM (tpep_dropoff_datetime - tpep_pickup_datetime)) > 60  -- At least 1 minute\nGROUP BY hour\nORDER BY hour\n\"\"\"\n).df()\nfare_analysis","key":"NGzck3ppGU"},{"type":"outputs","id":"pzr30vAdUx7pcXRerIPrY","children":[],"key":"iDS8cMlBYr"}],"key":"zooIXB5xDI"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.line_chart(fare_analysis, x=\"hour\", y=\"avg_fare_per_mile\", title=\"Average Fare Per Mile by Hour of Day\", x_label=\"Hour of Day\", y_label=\"Average Fare Per Mile\")","key":"eEDoV5bxVn"},{"type":"outputs","id":"gFdFwbVKUElqHPxqn1Iej","children":[],"key":"iz7Hzdeyv4"}],"key":"lbSuA5hXMC"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":467,"column":1},"end":{"line":467,"column":1}},"children":[{"type":"text","value":"Passenger Behavior Analysis","position":{"start":{"line":467,"column":1},"end":{"line":467,"column":1}},"key":"byOLkG4sOY"}],"identifier":"passenger-behavior-analysis","label":"Passenger Behavior Analysis","html_id":"passenger-behavior-analysis","implicit":true,"key":"BmOD4Hb4UY"}],"key":"cLyGiCuv86"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT\n    passenger_count,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_total,\n    ROUND(AVG(total_amount / passenger_count), 2) as avg_per_passenger,\n    ROUND(COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (), 2) as percentage,\nFROM trips\nWHERE passenger_count BETWEEN 1 AND 6\nGROUP BY passenger_count\nORDER BY passenger_count\n\"\"\"\n).show()","key":"laN5yAXpKk"},{"type":"outputs","id":"8MI0S-4fKyFG4UqzuP5Qu","children":[],"key":"hNYCZ52Gxb"}],"key":"zrgQlepkdh"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":487,"column":1},"end":{"line":487,"column":1}},"children":[{"type":"text","value":"Multi-Month Analysis","position":{"start":{"line":487,"column":1},"end":{"line":487,"column":1}},"key":"lLqiLnDlAs"}],"identifier":"multi-month-analysis","label":"Multi-Month Analysis","html_id":"multi-month-analysis","implicit":true,"key":"T6B26eEmtL"}],"key":"zOy68R8UvG"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"months = range(1, 10)\nmonths_to_analyze = [f\"yellow_tripdata_2025-{month:02d}.parquet\" for month in months]\n\nmonthly_comparison = con.sql(\n    f\"\"\"\nSELECT\n    EXTRACT(YEAR FROM tpep_pickup_datetime) as year,\n    EXTRACT(MONTH FROM tpep_pickup_datetime) as month,\n    COUNT(*) as trip_count,\n    ROUND(AVG(trip_distance), 2) as avg_distance,\n    ROUND(AVG(total_amount), 2) as avg_fare,\n    SUM(total_amount) as total_revenue,\nFROM read_parquet([{','.join([f\"'https://d37ci6vzurychx.cloudfront.net/trip-data/{m}'\" for m in months_to_analyze])}])\nWHERE year = 2025\nGROUP BY year, month\nORDER BY year, month\n\"\"\"\n).df()\n\nmonthly_comparison","key":"MlhItfLBBY"},{"type":"outputs","id":"woGI9NVz5g2XdkCFJGg8F","children":[],"key":"ZLUTGR5doV"}],"key":"r0YiwVEpE3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Visualize monthly trends\nmonthly_comparison[\"month_label\"] = monthly_comparison.apply(\n    lambda x: f\"{int(x['year'])}-{int(x['month']):02d}\", axis=1\n)\n\nleafmap.bar_chart(monthly_comparison, x=\"month_label\",     y=\"trip_count\",\n    title=\"Monthly Taxi Trip Volume\", x_label=\"Month\", y_label=\"Number of Trips\" )","key":"Q4rTje5ZU5"},{"type":"outputs","id":"PDoTRflbm42xQVN08K0t7","children":[],"key":"OfoSNT34Sy"}],"key":"zsX5JzDF9s"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":522,"column":1},"end":{"line":522,"column":1}},"children":[{"type":"text","value":"Visualization","position":{"start":{"line":522,"column":1},"end":{"line":522,"column":1}},"key":"nkTmJbCYl1"}],"identifier":"visualization","label":"Visualization","html_id":"visualization","implicit":true,"key":"FCqlBthDlu"},{"type":"heading","depth":3,"position":{"start":{"line":524,"column":1},"end":{"line":524,"column":1}},"children":[{"type":"text","value":"Aggregating Trip Data by Zone","position":{"start":{"line":524,"column":1},"end":{"line":524,"column":1}},"key":"NjisCXKwEN"}],"identifier":"aggregating-trip-data-by-zone","label":"Aggregating Trip Data by Zone","html_id":"aggregating-trip-data-by-zone","implicit":true,"key":"U7Rj5NYFuX"}],"key":"IYSrCFza94"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pickup_df = con.sql(\n    \"\"\"\n    SELECT PULocationID, COUNT(*) as pickup_count\n    FROM trips\n    GROUP BY PULocationID\n    \"\"\"\n).df()\npickup_df","key":"Et8QV0DwSF"},{"type":"outputs","id":"3bWOD-s2TsQ9Fppx5USOD","children":[],"key":"RFUAVyc99H"}],"key":"ksH1jmWAdQ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dropoff_df = con.sql(\n    \"\"\"\n    SELECT DOLocationID, COUNT(*) as dropoff_count\n    FROM trips\n    GROUP BY DOLocationID\n    \"\"\"\n).df()\ndropoff_df","key":"DpsrfscrSM"},{"type":"outputs","id":"BSzICBdOA8AlCOppwhWPe","children":[],"key":"zFH4P2uo67"}],"key":"LiAUhhBhK0"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":548,"column":1},"end":{"line":548,"column":1}},"children":[{"type":"text","value":"Merging with Geographic Data","position":{"start":{"line":548,"column":1},"end":{"line":548,"column":1}},"key":"HIlhW0A5