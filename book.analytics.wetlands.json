olumn":1}},"key":"AVnuIni7LG"}],"identifier":"environment-setup-and-extension-loading","label":"Environment Setup and Extension Loading","html_id":"environment-setup-and-extension-loading","implicit":true,"key":"kkDOalKp3m"}],"key":"X2dPyWfWCv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# %pip install duckdb leafmap","key":"Qbn88Ok5NU"},{"type":"outputs","id":"pXiqJ4kLggZR80c1s7hwP","children":[],"key":"nWaEQm0pYP"}],"key":"NQDEWpYrJa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import duckdb\n\n# Create an in-memory DuckDB connection\ncon = duckdb.connect()\n\n# Install and load the spatial extension for geometry operations\ncon.install_extension(\"spatial\")\ncon.load_extension(\"spatial\")","key":"SNPX41yVwQ"},{"type":"outputs","id":"Gy4hMjCM6hZo294fPR7ob","children":[],"key":"TTU5yytd2e"}],"key":"NYawB3ZrYS"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Querying a Single State’s Wetlands","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"G1Wze5c5Ej"}],"identifier":"querying-a-single-states-wetlands","label":"Querying a Single State’s Wetlands","html_id":"querying-a-single-states-wetlands","implicit":true,"key":"lnArcxaSRu"}],"key":"scLqGarIl9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Select a state to analyze (DC has a manageable dataset size for initial exploration)\nstate = \"DC\"  # You can change this to any two-letter state code like \"FL\", \"CA\", \"TX\"\n\n# Construct the URL to the GeoParquet file hosted on Source Cooperative\nurl = f\"https://data.source.coop/giswqs/nwi/wetlands/{state}_Wetlands.parquet\"\n\n# Query the wetland data directly from cloud storage\n# DuckDB automatically handles the HTTPS connection and Parquet parsing\ncon.sql(f\"SELECT * FROM '{url}'\")","key":"lTGb4A2qMT"},{"type":"outputs","id":"3bU_BoWjHEaVeI87MTUX_","children":[],"key":"LlI7HXlIg8"}],"key":"tixnzBsIXe"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"Inspecting the Data Schema","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"aNDhrKft8E"}],"identifier":"inspecting-the-data-schema","label":"Inspecting the Data Schema","html_id":"inspecting-the-data-schema","implicit":true,"key":"r4Jzf1nxlr"}],"key":"QD8xkMxYBT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(f\"DESCRIBE SELECT * FROM '{url}'\")","key":"oJotkDMEA7"},{"type":"outputs","id":"XsAazRf4W2tym_hAbbPbD","children":[],"key":"P6HMrHUjgB"}],"key":"gTYcw0poMk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(f\"SELECT DISTINCT WETLAND_TYPE FROM '{url}'\")","key":"tHzGPVHk5N"},{"type":"outputs","id":"zqrrgL1-irdcibmXB6C4w","children":[],"key":"K7TLZORonU"}],"key":"Sb8v7iH1Y2"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"text","value":"Alternative Access Methods","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"qlf3wzR2oj"}],"identifier":"alternative-access-methods","label":"Alternative Access Methods","html_id":"alternative-access-methods","implicit":true,"key":"a178BfrBlq"},{"type":"code","lang":"bash","value":"aws s3 ls s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/","position":{"start":{"line":80,"column":1},"end":{"line":82,"column":1}},"key":"nBZhealwrC"},{"type":"code","lang":"bash","value":"aws s3 ls s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/ --recursive --summarize | grep \"Total Size\" | awk '{print $3/1024/1024/1024 \" GB\"}'","position":{"start":{"line":84,"column":1},"end":{"line":86,"column":1}},"key":"RaZnQ6tYSS"},{"type":"heading","depth":2,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Visualizing Wetland Distributions","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"ZJJv2lRiPW"}],"identifier":"visualizing-wetland-distributions","label":"Visualizing Wetland Distributions","html_id":"visualizing-wetland-distributions","implicit":true,"key":"oEZaQqQhdA"},{"type":"heading","depth":3,"position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"children":[{"type":"text","value":"Loading and Preparing State-Level Data","position":{"start":{"line":90,"column":1},"end":{"line":90,"column":1}},"key":"AfFHKJXwtj"}],"identifier":"loading-and-preparing-state-level-data","label":"Loading and Preparing State-Level Data","html_id":"loading-and-preparing-state-level-data","implicit":true,"key":"WRPRooZa9X"}],"key":"VefhvvPuM9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import leafmap.maplibregl as leafmap","key":"IineKVZDnI"},{"type":"outputs","id":"CwwyYNsD3mqRKpnbtMUZn","children":[],"key":"ltiDpWrUeB"}],"key":"PjmC5XuSz3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"state = \"DC\"  # Washington DC has a manageable dataset size for visualization\nurl = f\"https://data.source.coop/giswqs/nwi/wetlands/{state}_Wetlands.parquet\"\n\n# Read the Parquet file from cloud storage and convert to a GeoDataFrame\n# src_crs='EPSG:5070' specifies the Albers Equal Area Conic projection (used in NWI data)\n# dst_crs='EPSG:4326' reprojects to WGS84 latitude/longitude (required for web mapping)\n# return_type='gdf' ensures we get a GeoPandas GeoDataFrame with spatial capabilities\ngdf = leafmap.read_vector(\n    url, return_type=\"gdf\", src_crs=\"EPSG:5070\", dst_crs=\"EPSG:4326\"\n)\n\n# Display basic statistics about the loaded dataset\nprint(f\"Number of wetland features: {len(gdf):,}\")\nprint(f\"Unique wetland types: {gdf['WETLAND_TYPE'].nunique()}\")\nprint(f\"Total wetland area: {gdf['Shape_Area'].sum() / 1_000_000:.2f} sq km\")","key":"hylMRScb0V"},{"type":"outputs","id":"Vah719JM5WsFbSMtokmJY","children":[],"key":"ecLUXrJ5LE"}],"key":"lRJHr0MkGN"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"children":[{"type":"text","value":"Creating Thematic Visualizations by Wetland Type","position":{"start":{"line":114,"column":1},"end":{"line":114,"column":1}},"key":"cNZaLAP82Z"}],"identifier":"creating-thematic-visualizations-by-wetland-type","label":"Creating Thematic Visualizations by Wetland Type","html_id":"creating-thematic-visualizations-by-wetland-type","implicit":true,"key":"YElV3VJLCv"}],"key":"w3RX2Ml69q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a new interactive map centered on the data\nm = leafmap.Map()\n\n# Add a high-resolution satellite imagery basemap for context\n# This helps identify wetland relationships with land use and landscape features\nm.add_basemap(\"Esri.WorldImagery\")\n\n# Define colors for each wetland type using RGB values\ncolor_map = {\n    \"Freshwater Forested/Shrub Wetland\": (0, 136, 55),  # Dark green\n    \"Freshwater Emergent Wetland\": (127, 195, 28),  # Bright green\n    \"Freshwater Pond\": (104, 140, 192),  # Light blue\n    \"Estuarine and Marine Wetland\": (102, 194, 165),  # Teal\n    \"Riverine\": (1, 144, 191),  # Medium blue\n    \"Lake\": (19, 0, 124),  # Dark blue\n    \"Estuarine and Marine Deepwater\": (0, 124, 136),  # Deep teal\n    \"Other\": (178, 134, 86),  # Brown\n}\n\n\n# Helper function to convert RGB tuples to RGBA strings with transparency\ndef rgba(rgb, a=0.85):\n    r, g, b = rgb\n    return f\"rgba({r},{g},{b},{a})\"\n\n\n# Build a MapLibre GL style expression for conditional coloring\n# The \"match\" expression looks up each feature's WETLAND_TYPE and applies the corresponding color\nfill_match = [\"match\", [\"get\", \"WETLAND_TYPE\"]]\nfor wetland_type, color in color_map.items():\n    fill_match += [wetland_type, rgba(color)]\n# Add a default gray color for any wetland types not in our color map\nfill_match += [\"rgba(200,200,200,0.6)\"]\n\n# Define the paint properties for the wetland polygons\npaint = {\n    \"fill-color\": fill_match,  # Apply conditional colors\n    \"fill-outline-color\": \"rgba(0,0,0,0.25)\",  # Subtle dark outlines\n}\n\n# Add the wetland GeoDataFrame to the map as filled polygons\nm.add_vector(gdf, layer_type=\"fill\", paint=paint, name=\"Wetlands\")\n\n# Add a legend explaining the color scheme\nm.add_legend(builtin_legend=\"NWI\", title=\"Wetland Type\")\n\n# Display the map\nm","key":"NcBiGpL735"},{"type":"outputs","id":"ioD_GNJEQ4VEFmUW6wQPQ","children":[],"key":"A377VGyzWG"}],"key":"e1EahVOXrH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Alternative simplified approach using leafmap's built-in NWI styling\nm = leafmap.Map()\nm.add_basemap(\"Esri.WorldImagery\")\nm.add_nwi(gdf, name=\"Wetlands\")\nm.add_legend(builtin_legend=\"NWI\", title=\"Wetland Type\")\nm","key":"ayIUSHvthd"},{"type":"outputs","id":"23QO8c84ZanSc33Opg5RP","children":[],"key":"aprjks7yok"}],"key":"qQZAs5pQcW"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"children":[{"type":"text","value":"National-Scale Wetland Analysis","position":{"start":{"line":176,"column":1},"end":{"line":176,"column":1}},"key":"dHLNmjx6Yh"}],"identifier":"national-scale-wetland-analysis","label":"National-Scale Wetland Analysis","html_id":"national-scale-wetland-analysis","implicit":true,"key":"Cm1VTPUXNy"},{"type":"heading","depth":3,"position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"Counting All Wetland Features Nationally","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"PGsY4wmbCI"}],"identifier":"counting-all-wetland-features-nationally","label":"Counting All Wetland Features Nationally","html_id":"counting-all-wetland-features-nationally","implicit":true,"key":"xO851bugiI"}],"key":"yPuItgG2XO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    f\"\"\"\nSELECT COUNT(*) AS Count\nFROM 's3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet'\n\"\"\"\n)","key":"a8nJze7ex9"},{"type":"outputs","id":"7snsckUrhpLFxCGcwXC8A","children":[],"key":"LQMkzwGCf4"}],"key":"TjckmAU5fF"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"children":[{"type":"text","value":"Analyzing Wetlands by State","position":{"start":{"line":189,"column":1},"end":{"line":189,"column":1}},"key":"Yz9fK0hNGA"}],"identifier":"analyzing-wetlands-by-state","label":"Analyzing Wetlands by State","html_id":"analyzing-wetlands-by-state","implicit":true,"key":"j1a2lfO91z"}],"key":"fHxf0hdwmv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = con.sql(\n    f\"\"\"\nSELECT filename, COUNT(*) AS Count\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY filename\nORDER BY COUNT(*) DESC;\n\"\"\"\n).df()\ndf.head()","key":"mqoetebi0i"},{"type":"outputs","id":"P2kvX9KV-Oq4E2EhdnFqv","children":[],"key":"W1xSBx5agn"}],"key":"XqVFSv7ybC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df[\"filename\"].tolist()","key":"ucnnIB5aRp"},{"type":"outputs","id":"wgsRxiqli1N2oC5abSgTm","children":[],"key":"wgbgHWl3LI"}],"key":"kQgoC3KSMe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"count_df = con.sql(\n    f\"\"\"\nSELECT SUBSTRING(filename, LENGTH(filename) - 18, 2) AS State, COUNT(*) AS Count\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY State\nORDER BY COUNT(*) DESC;\n\"\"\"\n).df()\ncount_df.head(10)","key":"tj7MZigQg3"},{"type":"outputs","id":"yT2bOpjeEoib7XLVsNR_w","children":[],"key":"ndEZYRBjnN"}],"key":"OO61iXp8Qb"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"children":[{"type":"text","value":"Creating Tables for Spatial Joins","position":{"start":{"line":219,"column":1},"end":{"line":219,"column":1}},"key":"WPYkZN0Pm6"}],"identifier":"creating-tables-for-spatial-joins","label":"Creating Tables for Spatial Joins","html_id":"creating-tables-for-spatial-joins","implicit":true,"key":"x8AXU7DIvq"}],"key":"dsrOTkN7rO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\"CREATE OR REPLACE TABLE wetlands AS FROM count_df\")\ncon.sql(\"FROM wetlands\")","key":"x03q9Cep9I"},{"type":"outputs","id":"q3qEANEOrZ_lbSvD-kLhD","children":[],"key":"vL5QphBb5K"}],"key":"Yh4LaCOcWA"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"children":[{"type":"text","value":"Loading State Boundaries for Mapping","position":{"start":{"line":226,"column":1},"end":{"line":226,"column":1}},"key":"ug1Tqp86nd"}],"identifier":"loading-state-boundaries-for-mapping","label":"Loading State Boundaries for Mapping","html_id":"loading-state-boundaries-for-mapping","implicit":true,"key":"Ij0oARMW90"}],"key":"R48o2wezxg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"url = \"https://data.gishub.org/us/us_states.parquet\"\ncon.sql(\n    f\"\"\"\nCREATE OR REPLACE TABLE states AS\nSELECT * FROM '{url}'\n\"\"\"\n)\ncon.sql(\"FROM states\")","key":"chTkvrLQxX"},{"type":"outputs","id":"-7Ngj54DO0TZIlFCYf1lk","children":[],"key":"oXqcB64tSG"}],"key":"IuH2MrRwOU"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"children":[{"type":"text","value":"Joining Wetland Statistics with State Geometries","position":{"start":{"line":239,"column":1},"end":{"line":239,"column":1}},"key":"jgIA4ErVvi"}],"identifier":"joining-wetland-statistics-with-state-geometries","label":"Joining Wetland Statistics with State Geometries","html_id":"joining-wetland-statistics-with-state-geometries","implicit":true,"key":"nIpP04Dj7g"}],"key":"Z554Ptlmdg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"con.sql(\n    \"\"\"\nSELECT * FROM states INNER JOIN wetlands ON states.id = wetlands.State\n\"\"\"\n)","key":"KaYDL4JD1W"},{"type":"outputs","id":"ifanYCnrdBCZYC0fMOvSA","children":[],"key":"GhxJcD33Sf"}],"key":"nsmtL4bMfk"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":249,"column":1},"end":{"line":249,"column":1}},"children":[{"type":"text","value":"Preparing Data for Visualization","position":{"start":{"line":249,"column":1},"end":{"line":249,"column":1}},"key":"ivD65x8fFm"}],"identifier":"preparing-data-for-visualization","label":"Preparing Data for Visualization","html_id":"preparing-data-for-visualization","implicit":true,"key":"OtFQOSiSV7"}],"key":"vCcJsxfqdD"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df = con.sql(\n    \"\"\"\nSELECT name, State, Count, ST_AsText(geometry) as geometry\nFROM states INNER JOIN wetlands ON states.id = wetlands.State\n\"\"\"\n).df()\ndf.head()","key":"sCdv1