, \"State\", \"Area_SqKm\", height=900, title=\"Wetland Area by State\"\n)","key":"T1TEsrtdR2"},{"type":"outputs","id":"vCLhE__1OVwKl_qNL86TR","children":[],"key":"hLnd4G2pms"}],"key":"B8SmbEjahJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.bar_chart(area_df, \"State\", \"Area_SqKm\", title=\"Wetland Area by State\")","key":"km5dkoyj9m"},{"type":"outputs","id":"beAHrbBRkFuKFHgVng1ID","children":[],"key":"xLtBOxT05N"}],"key":"G6nX4hcWdX"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":325,"column":1},"end":{"line":325,"column":1}},"children":[{"type":"text","value":"Classification by Wetland Type","position":{"start":{"line":325,"column":1},"end":{"line":325,"column":1}},"key":"gHPUr9X2E0"}],"identifier":"classification-by-wetland-type","label":"Classification by Wetland Type","html_id":"classification-by-wetland-type","implicit":true,"key":"drO8SjYsM0"}],"key":"xNkyyxTJZY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"type_df = con.sql(\n    f\"\"\"\nSELECT WETLAND_TYPE,\n       COUNT(*) AS count,\n       ROUND(SUM(Shape_Area) / 1e6, 0) AS area_sqkm\nFROM 's3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet'\nGROUP BY WETLAND_TYPE\nORDER BY area_sqkm DESC\n\"\"\"\n).df()\ntype_df.head(10)","key":"e4XOoPNrb5"},{"type":"outputs","id":"nbnuEzWflLzhF4568URav","children":[],"key":"RSGa6Q0FZV"}],"key":"i4gKRXDBVs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"by_state_type = con.sql(\n    f\"\"\"\nSELECT SUBSTRING(filename, LENGTH(filename) - 18, 0) AS State,\n       WETLAND_TYPE,\n       ROUND(SUM(Shape_Area) / 1e6, 2) AS area_sqkm\nFROM read_parquet('s3://us-west-2.opendata.source.coop/giswqs/nwi/wetlands/*.parquet', filename=true)\nGROUP BY State, WETLAND_TYPE\nQUALIFY ROW_NUMBER() OVER (PARTITION BY State ORDER BY area_sqkm DESC) <= 10\nORDER BY State, area_sqkm DESC\n\"\"\"\n).df()\nby_state_type.head(20)","key":"povMZ97X6W"},{"type":"outputs","id":"XqspIqjT4tadX6Kz6UIs4","children":[],"key":"XdWYjuiqX8"}],"key":"EbCBz5Pi6a"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"leafmap.pie_chart(\n    type_df, \"WETLAND_TYPE\", \"area_sqkm\", title=\"National Wetland Area by Type\"\n)","key":"vvV04QHM61"},{"type":"outputs","id":"JAc72ZacI61xMUQj6duIP","children":[],"key":"A5oPJATY1m"}],"key":"TPmHCoUoaC"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":362,"column":1},"end":{"line":362,"column":1}},"children":[{"type":"text","value":"Key Takeaways","position":{"start":{"line":362,"column":1},"end":{"line":362,"column":1}},"key":"d15mrlB8HQ"}],"identifier":"key-takeaways","label":"Key Takeaways","html_id":"key-takeaways","implicit":true,"key":"aOqetT6wsl"},{"type":"heading","depth":2,"position":{"start":{"line":364,"column":1},"end":{"line":364,"column":1}},"children":[{"type":"text","value":"Exercises","position":{"start":{"line":364,"column":1},"end":{"line":364,"column":1}},"key":"KFLk8wMVJO"}],"identifier":"exercises","label":"Exercises","html_id":"exercises","implicit":true,"key":"iIGJ8i42WE"},{"type":"heading","depth":3,"position":{"start":{"line":366,"column":1},"end":{"line":366,"column":1}},"children":[{"type":"text","value":"Exercise 1: State-Level Wetland Analysis","position":{"start":{"line":366,"column":1},"end":{"line":366,"column":1}},"key":"Wxzb60XxYU"}],"identifier":"exercise-1-state-level-wetland-analysis","label":"Exercise 1: State-Level Wetland Analysis","html_id":"exercise-1-state-level-wetland-analysis","implicit":true,"key":"gRzOY0BC3t"}],"key":"t2mQHKDJJH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"gDnSGJVnzX"},{"type":"outputs","id":"Reuo6qIbSeuYw8FpfWrA6","children":[],"key":"c1jR2EvbKC"}],