sition":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"tCGGI4hExh"}],"identifier":"understanding-duckdb-relations","label":"Understanding DuckDB Relations","html_id":"understanding-duckdb-relations","implicit":true,"key":"QvfvkxbChL"}],"key":"ywu06sejJt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"cities = con.read_csv(\"https://data.gishub.org/duckdb/cities.csv\")\nlarge_cities = cities.filter(\"population > 1000000\").order(\"population DESC\").limit(10)\nlarge_cities.show()","key":"NTSLbV9P5H"},{"type":"outputs","id":"EPg0wo3CqlhmSLVl_hXDa","children":[],"key":"r6nIFeuJFr"}],"key":"ovh6xdh4Hk"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"Seamless Integration with Pandas DataFrames","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"eH5vrkx6wb"}],"identifier":"seamless-integration-with-pandas-dataframes","label":"Seamless Integration with Pandas DataFrames","html_id":"seamless-integration-with-pandas-dataframes","implicit":true,"key":"FQiZiwQ0P1"},{"type":"heading","depth":3,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"Querying DataFrames with SQL","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"JFjSQQehw0"}],"identifier":"querying-dataframes-with-sql","label":"Querying DataFrames with SQL","html_id":"querying-dataframes-with-sql","implicit":true,"key":"oapUhhZQNH"}],"key":"IIMDjCU4gC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"pandas_df = pd.DataFrame({\"a\": [42]})\ncon.sql(\"SELECT * FROM pandas_df\")","key":"t3uCApi6Y7"},{"type":"outputs","id":"itEN48BV_lfcEVg5RxwRh","children":[],"key":"tRTaDtwoN7"}],"key":"FknfhVJAqg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Load cities data into a pandas DataFrame\ncities_df = con.read_csv(\"https://data.gishub.org/duckdb/cities.csv\").df()\nprint(f\"Loaded {len(cities_df)} cities into pandas DataFrame\")\ncities_df.head()","key":"BpPYuutrFv"},{"type":"outputs","id":"ZPvBduN0Bu96H_7k_i81c","children":[],"key":"XM7qcatwN1"}],"key":"rL4wVUSGkF"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"children":[{"type":"text","value":"The Bidirectional Workflow","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"Nzon3zX5CC"}],"identifier":"the-bidirectional-workflow","label":"The Bidirectional Workflow","html_id":"the-bidirectional-workflow","implicit":true,"key":"svd0HIk4ZP"}],"key":"j8WLp0zrsu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Query the pandas DataFrame using SQL\nlarge_cities = con.sql(\n    \"\"\"\n    SELECT name, country, population\n    FROM cities_df\n    WHERE population > 5000000\n    ORDER BY population DESC\n    LIMIT 10\n\"\"\"\n)\nlarge_cities.show()","key":"ofbjrHADGk"},{"type":"outputs","id":"mRvUN7hLsZUtVOdGXaQnp","children":[],"key":"tFF3KVTsNT"}],"key":"yP0UTY3rE9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Step 1: Use SQL for initial filtering (DuckDB's strength)\ncities_rel = con.sql(\n    \"\"\"\n    SELECT * FROM read_csv_auto('https://data.gishub.org/duckdb/cities.csv')\n    WHERE population > 100000\n\"\"\"\n)\n\n# Step 2: Convert to DataFrame for pandas operations\ncities_df = cities_rel.df()\n\n# Step 3: Use pandas for complex transformations\ncities_df[\"pop_millions\"] = cities_df[\"population\"] / 1_000_000\ncities_df[\"hemisphere\"] = cities_df[\"latitude\"].apply(\n    lambda x: \"North\" if x > 0 else \"South\"\n)\n\n# Step 4: Query the transformed DataFrame with SQL\nresult = con.sql(\n    \"\"\"\n    SELECT hemisphere, COUNT(*) as city_count,\n           AVG(pop_millions) as avg_pop_millions\n    FROM cities_df\n    GROUP BY hemisphere\n\"\"\"\n)\nresult.show()","key":"KtxoUrx0xQ"},{"type":"outputs","id":"2wi7JAEqkLTQxmAs2pY5w","children":[],"key":"ZFCNT99coE"}],"key":"VROMeIJ01D"},{"type":"block","children":[{"type":"heading","depth":3,"position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"Performance Considerations","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"r9QiSS0pT6"}],"identifier":"performance-considerations","label":"Performance Considerations","html_id":"performance-considerations","implicit":true,"key":"BqrEoQIyAb"},{"type":"heading","depth":2,"position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"children":[{"type":"text","value":"Polars Interoperability","position":{"start":{"line":150,"column":1},"end":{"line":150,"column":1}},"key":"IEgBpgTPxi"}],"identifier":"polars-interoperability","label":"Polars Interoperability","html_id":"polars-interoperability","implicit":true,"key":"CfTRXiWeb1"}],"key":"ND9v6IoAO0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# %pip install polars\nimport polars as pl\n\n# Convert DuckDB result to Polars via pandas\npl_df = pl.from_pandas(con.sql(\"SELECT * FROM range(10)\").df())\npl_df.head()\n\n# Query Polars DataFrame in DuckDB\ncon.sql(\"SELECT COUNT(*) AS n FROM pl_df\")","key":"oAM6G6IKP5"},{"type":"outputs","id":"qISVptD618BckgFxQEXwV","children":[],"key":"fZRRxed0A1"}],"key":"c8M3UnnfM3"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"text","value":"Result Conversion and Output Formats","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"uSqZ